---
import '../styles/global.css';
import SEOHead, { type SeoProps } from '../components/seo/SEOHead.astro';
import SchemaJsonLd from '../components/seo/SchemaJsonLd.astro';
import { site } from '../data/business';
import { wrapSchemaGraph } from '../data/schema';
import inter400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import inter700 from '@fontsource/inter/files/inter-latin-700-normal.woff2?url';

interface Props {
  seo?: SeoProps;
  schemaGraph?: unknown[];
}

const defaultSeo: SeoProps = {
  title: 'Veteran-Owned Handyman | Katy & West Houston | EYS',
  description:
    'Looking for a handyman near you in Katy or West Houston? Elevate Your Space handles repairs, installations, painting, drywall, and more. Free estimates.',
  canonical: site.url,
};

const { seo = defaultSeo, schemaGraph = [] } = Astro.props;
const schemaData = schemaGraph.length ? wrapSchemaGraph(schemaGraph) : null;

// Only load Google Analytics on production builds (not GitHub Pages base-path previews).
const enableAnalytics = import.meta.env.PROD && (import.meta.env.BASE_URL || '/') === '/';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <SEOHead {...seo} />
    <link rel="preload" href={inter400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={inter700} as="font" type="font/woff2" crossorigin />
    {schemaData && <SchemaJsonLd data={schemaData} />}
    {
      enableAnalytics && (
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          function loadGtag() {
            if (document.querySelector('script[data-eys-gtag]')) return;
            var s = document.createElement('script');
            s.async = true;
            s.src = 'https://www.googletagmanager.com/gtag/js?id=G-9D5MCDT0L1';
            s.dataset.eysGtag = 'true';
            s.onload = function () {
              gtag('js', new Date());
              gtag('config', 'G-9D5MCDT0L1');
            };
            document.head.appendChild(s);
          }
          function scheduleGtag() {
            if ('requestIdleCallback' in window) {
              requestIdleCallback(loadGtag, { timeout: 4000 });
            } else {
              window.addEventListener('load', function () {
                setTimeout(loadGtag, 1);
              });
            }
          }
          scheduleGtag();
        </script>
      )
    }
  </head>
  <body
    class="font-sans text-brand-charcoal bg-brand-lightbg antialiased selection:bg-brand-red selection:text-white"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-white focus:text-brand-black focus:rounded-md focus:shadow-lg focus:ring-2 focus:ring-brand-red"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>
