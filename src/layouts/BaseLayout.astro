---
import '../styles/global.css';
import SEOHead, { type SeoProps } from '../components/seo/SEOHead.astro';
import SchemaJsonLd from '../components/seo/SchemaJsonLd.astro';
import { site } from '../data/business';
import { wrapSchemaGraph } from '../data/schema';

interface Props {
  seo?: SeoProps;
  schemaGraph?: unknown[];
}

const defaultSeo: SeoProps = {
  title: 'Handyman Services in Katy, TX | Elevate Your Space Handyman',
  description:
    'Veteran-owned handyman services in Katy, Texas. Elevate Your Space Handyman provides repairs, installations, remodeling, painting, drywall, cabinets, flooring, and more. Call today for reliable local service.',
  canonical: site.url,
};

const { seo = defaultSeo, schemaGraph = [] } = Astro.props;
const schemaData = schemaGraph.length ? wrapSchemaGraph(schemaGraph) : null;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <SEOHead {...seo} />
    {schemaData && <SchemaJsonLd data={schemaData} />}
  </head>
  <body
    class="font-sans text-brand-charcoal bg-brand-lightbg antialiased selection:bg-brand-red selection:text-white"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-white focus:text-brand-black focus:rounded-md focus:shadow-lg focus:ring-2 focus:ring-brand-red"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>
