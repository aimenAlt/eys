---
import ContentLayout from './ContentLayout.astro';
import BreadcrumbNav from '../components/seo/BreadcrumbNav.astro';
import AreaHero from '../components/areas/AreaHero.astro';
import AreaNeighborhoods from '../components/areas/AreaNeighborhoods.astro';
import AreaServicesLinks from '../components/areas/AreaServicesLinks.astro';
import AreaProjectsPlaceholder from '../components/areas/AreaProjectsPlaceholder.astro';
import AreaFAQ from '../components/areas/AreaFAQ.astro';
import CTASection from '../components/home/CTASection.astro';
import { absoluteUrl } from '../data/business';
import {
  breadcrumbList,
  faqPage,
  localBusinessForArea,
  webPage,
} from '../data/schema';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'serviceAreas'>;
}

const { entry } = Astro.props;
const { data } = entry;
const pageUrl = absoluteUrl(`/service-areas/${data.slug}/`);
const title = data.seoTitle ?? `Handyman Services in ${data.title} | Elevate Your Space Handyman`;
const description =
  data.metaDescription ?? data.summary ?? `Handyman services in ${data.title}.`;

const schemaGraph = [
  webPage(data.heroTitle ?? data.title, pageUrl, description),
  breadcrumbList([
    { name: 'Home', url: absoluteUrl('/') },
    { name: 'Service Areas', url: absoluteUrl('/service-areas/') },
    { name: data.title, url: pageUrl },
  ]),
  localBusinessForArea(data.title, pageUrl),
  data.faqs?.length ? faqPage(data.faqs) : null,
].filter(Boolean);
---

<ContentLayout
  seo={{ title, description, canonical: pageUrl, ogType: 'website' }}
  schemaGraph={schemaGraph}
>
  <article class="pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <BreadcrumbNav
        items={[
          { name: 'Home', url: '/' },
          { name: 'Service Areas', url: '/service-areas/' },
          { name: data.title, url: `/service-areas/${data.slug}/` },
        ]}
      />
    </div>
    <AreaHero area={data} />
    <AreaNeighborhoods neighborhoods={data.neighborhoods} localIntro={data.localIntro} />
    <AreaServicesLinks serviceSlugs={data.servicesAvailable} cityName={data.title} />
    <AreaProjectsPlaceholder message={data.relatedProjectsPlaceholder} />
    <section class="py-12 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-gray max-w-none">
        <slot />
      </div>
    </section>
    <AreaFAQ faqs={data.faqs} />
    <CTASection />
  </article>
</ContentLayout>
