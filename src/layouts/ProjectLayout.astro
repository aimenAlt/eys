---
import ContentLayout from './ContentLayout.astro';
import BreadcrumbNav from '../components/seo/BreadcrumbNav.astro';
import ProjectGallery from '../components/projects/ProjectGallery.astro';
import CTASection from '../components/home/CTASection.astro';
import { absoluteUrl, resolveOgImage } from '../data/business';
import { breadcrumbList, webPage } from '../data/schema';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { data } = entry;
const pageUrl = absoluteUrl(`/projects/${data.slug}/`);
const title = `${data.title} | Elevate Your Space Handyman`;
const description = data.summary ?? `Project completed by Elevate Your Space Handyman.`;

const featuredImage =
  data.gallery?.find((img) => img.featured)?.src ?? data.gallery?.[0]?.src;

const schemaGraph = [
  webPage(data.title, pageUrl, description),
  breadcrumbList([
    { name: 'Home', url: absoluteUrl('/') },
    { name: 'Projects', url: absoluteUrl('/projects/') },
    { name: data.title, url: pageUrl },
  ]),
];
---

<ContentLayout
  seo={{
    title,
    description,
    canonical: pageUrl,
    ogType: 'article',
    ogImage: resolveOgImage(featuredImage),
  }}
  schemaGraph={schemaGraph}
>
  <article class="pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <BreadcrumbNav
        items={[
          { name: 'Home', url: '/' },
          { name: 'Projects', url: '/projects/' },
          { name: data.title, url: `/projects/${data.slug}/` },
        ]}
      />
    </div>
    <section class="py-12 bg-white" aria-labelledby="project-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 id="project-heading" class="text-3xl md:text-4xl font-bold text-brand-black mb-4">
          {data.title}
        </h1>
        {data.summary && <p class="text-lg text-gray-600 mb-6 max-w-3xl">{data.summary}</p>}
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10 text-sm">
          {
            data.service && (
              <div>
                <dt class="font-bold text-brand-black">Service</dt>
                <dd class="text-gray-600">
                  <a href={`/services/${data.service}/`} class="text-brand-red font-medium hover:underline">
                    {data.service
                      .split('-')
                      .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
                      .join(' ')}
                  </a>
                </dd>
              </div>
            )
          }
          {
            data.location && (
              <div>
                <dt class="font-bold text-brand-black">Location</dt>
                <dd class="text-gray-600">{data.location}</dd>
              </div>
            )
          }
        </dl>
        <ProjectGallery images={data.gallery} />
      </div>
    </section>
    <section class="py-12 bg-brand-lightbg">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-gray max-w-none">
        <slot />
      </div>
    </section>
    <CTASection />
  </article>
</ContentLayout>
