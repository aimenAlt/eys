---
import ContentLayout from './ContentLayout.astro';
import BreadcrumbNav from '../components/seo/BreadcrumbNav.astro';
import ServiceHero from '../components/services/ServiceHero.astro';
import ServiceIncluded from '../components/services/ServiceIncluded.astro';
import ServicePriceFactors from '../components/services/ServicePriceFactors.astro';
import ServiceProcess from '../components/services/ServiceProcess.astro';
import ServiceFAQ from '../components/services/ServiceFAQ.astro';
import ServiceAreaCrossLinks from '../components/services/ServiceAreaCrossLinks.astro';
import LocalAreaCTA from '../components/areas/local/LocalAreaCTA.astro';
import { absoluteUrl } from '../data/business';
import { getCategoryForServiceSlug } from '../data/serviceCategories';
import {
  breadcrumbList,
  faqPage,
  serviceSchema,
  webPage,
} from '../data/schema';
import type { CollectionEntry } from 'astro:content';
import type { BreadcrumbItem } from '../data/schema';

interface Props {
  entry: CollectionEntry<'services'>;
  featuredCommunities: CollectionEntry<'communities'>[];
}

const { entry, featuredCommunities } = Astro.props;
const { data } = entry;
const pageUrl = absoluteUrl(`/services/${data.slug}/`);
const parentCategory = getCategoryForServiceSlug(data.slug);
const title = data.seoTitle ?? `${data.title} | Elevate Your Space Handyman`;
const description =
  data.metaDescription ?? data.summary ?? `Professional ${data.title} in Katy and West Houston.`;

const communityLinks = featuredCommunities.map((c) => ({
  title: c.data.title,
  href: `/service-areas/${c.data.citySlug}/${c.data.slug}/`,
}));

const breadcrumbItems: BreadcrumbItem[] = [
  { name: 'Home', url: absoluteUrl('/') },
  { name: 'Services', url: absoluteUrl('/services/') },
];
if (parentCategory) {
  breadcrumbItems.push({
    name: parentCategory.title,
    url: absoluteUrl(`/services/${parentCategory.slug}/`),
  });
}
breadcrumbItems.push({ name: data.title, url: pageUrl });

const navBreadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services/' },
  ...(parentCategory
    ? [{ name: parentCategory.title, url: `/services/${parentCategory.slug}/` }]
    : []),
  { name: data.title, url: `/services/${data.slug}/` },
];

const schemaGraph = [
  webPage(data.heroTitle ?? data.title, pageUrl, description),
  breadcrumbList(breadcrumbItems),
  serviceSchema(data.title, description, pageUrl),
  data.faqs?.length ? faqPage(data.faqs) : null,
].filter(Boolean);
---

<ContentLayout
  seo={{ title, description, canonical: pageUrl, ogType: 'website' }}
  schemaGraph={schemaGraph}
>
  <article class="pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <BreadcrumbNav items={navBreadcrumbItems} />
    </div>
    <ServiceHero service={data} />
    <ServiceIncluded items={data.includedServices} />
    <ServicePriceFactors items={data.priceFactors} />
    <ServiceProcess steps={data.process} />
    <section class="py-12 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-gray max-w-none">
        <slot />
      </div>
    </section>
    <ServiceAreaCrossLinks communities={communityLinks} />
    <ServiceFAQ faqs={data.faqs} />
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <LocalAreaCTA locationName="Katy & West Houston" />
    </div>
  </article>
</ContentLayout>
