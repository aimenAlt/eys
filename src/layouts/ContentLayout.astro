---
import BaseLayout from './BaseLayout.astro';
import type { SeoProps } from '../components/seo/SEOHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileStickyCTA from '../components/layout/MobileStickyCTA.astro';
import { getCollection } from 'astro:content';
import { buildNavMenus } from '../data/navMenus';

interface Props {
  seo: SeoProps;
  schemaGraph?: unknown[];
}

const { seo, schemaGraph = [] } = Astro.props;

const [services, serviceAreas, communities] = await Promise.all([
  getCollection('services'),
  getCollection('serviceAreas'),
  getCollection('communities'),
]);

const navMenus = buildNavMenus(services, serviceAreas, communities);
---

<BaseLayout seo={seo} schemaGraph={schemaGraph}>
  <Header navMenus={navMenus} />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <MobileStickyCTA />
</BaseLayout>
