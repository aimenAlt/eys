---
import ContentLayout from '../layouts/ContentLayout.astro';
import PageHero from '../components/common/PageHero.astro';
import BreadcrumbNav from '../components/seo/BreadcrumbNav.astro';
import CTASection from '../components/home/CTASection.astro';
import { absoluteUrl, business, site } from '../data/business';
import { breadcrumbList, webPage } from '../data/schema';

const title = `About Us | ${site.name}`;
const description =
  'Learn about Elevate Your Space Handyman — dependable repair, installation, and remodeling services for Katy and West Houston homeowners.';
const canonical = absoluteUrl('/about/');

const schemaGraph = [
  webPage('About Elevate Your Space Handyman', canonical, description),
  breadcrumbList([
    { name: 'Home', url: absoluteUrl('/') },
    { name: 'About', url: canonical },
  ]),
];
---

<ContentLayout seo={{ title, description, canonical }} schemaGraph={schemaGraph}>
  <article>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <BreadcrumbNav
        items={[
          { name: 'Home', url: '/' },
          { name: 'About', url: '/about/' },
        ]}
      />
    </div>

    <PageHero
      eyebrow="Who We Are"
      title="Elevate Your Space Handyman"
      description="Dependable handyman service for Katy and West Houston — focused on honest communication, clean workmanship, and results you can trust."
    />

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <div class="mb-12 lg:mb-0">
            <h2 class="text-3xl md:text-4xl font-bold text-brand-black mb-6">
              Professional Home Services in Katy, TX
            </h2>
            <p class="text-gray-600 mb-8 leading-relaxed">
              Elevate Your Space Handyman helps homeowners complete repairs, improvements, installations, and small remodeling projects with confidence. Whether the job is a drywall patch, door installation, bathroom update, cabinet improvement, painting project, or general home repair, our team focuses on getting the work done right.
            </p>
            <p class="text-gray-600 leading-relaxed">
              We serve homeowners throughout Katy and surrounding West Houston communities. From quick fixes to larger upgrades, our goal is to make your space safer, cleaner, more functional, and more comfortable.
            </p>
          </div>

          <div class="relative h-80 sm:h-96 lg:h-[500px]">
            <img
              src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=600"
              loading="lazy"
              class="absolute top-0 right-0 w-4/5 h-[75%] object-cover rounded-xl shadow-xl z-10 border-4 border-white"
              alt="Home improvement project in Katy, Texas"
            />
            <img
              src="https://images.unsplash.com/photo-1556910103-1c02745a872e?auto=format&fit=crop&q=80&w=600"
              loading="lazy"
              class="absolute bottom-0 left-0 w-3/4 h-[70%] object-cover rounded-xl shadow-2xl z-20 border-4 border-white"
              alt="Kitchen remodeling work in Texas"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-brand-lightbg border-y border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-brand-black">What We Stand For</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
            <h3 class="text-xl font-bold text-brand-black mb-3">Building Trust</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Honesty, professionalism, and quality on every project — with clear communication from start to finish.
            </p>
          </div>
          <div class="bg-brand-black p-8 rounded-xl shadow-sm text-white">
            <h3 class="text-xl font-bold mb-3">Experienced Professionals</h3>
            <p class="text-gray-300 text-sm leading-relaxed">
              Skilled handyman, repair, and home improvement work with a strong focus on safety and customer satisfaction.
            </p>
          </div>
          <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
            <h3 class="text-xl font-bold text-brand-black mb-3">Ensuring Quality</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Detail-focused repair, installation, and remodeling solutions built to last and look finished.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
          <div class="lg:col-span-8">
            <h2 class="text-3xl font-bold text-brand-black mb-6">Areas We Serve</h2>
            <p class="text-gray-600 mb-6 leading-relaxed">
              Based in Katy, Texas, we work with homeowners across the West Houston area. Service-area pages highlight local neighborhoods and available services as they are added.
            </p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-gray-700">
              {
                business.areaServed.map((city) => (
                  <li class="flex items-center">
                    <svg
                      class="w-5 h-5 text-brand-red mr-2 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {city}
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="lg:col-span-4 bg-brand-lightbg p-6 rounded-xl border border-gray-200">
            <h3 class="font-bold text-brand-black mb-4">Ready to get started?</h3>
            <p class="text-sm text-gray-600 mb-6">
              Call or email to discuss your project. We will walk you through next steps and scheduling options.
            </p>
            <a
              href="/contact/"
              class="inline-block w-full text-center bg-brand-red text-white font-bold py-3 px-4 rounded hover:bg-brand-redhover transition-colors"
            >
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </section>

    <CTASection />
  </article>
</ContentLayout>
