---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import BreadcrumbNav from '../../components/seo/BreadcrumbNav.astro';
import BalancedGrid from '../../components/ui/BalancedGrid.astro';
import LocalAreaCTA from '../../components/areas/local/LocalAreaCTA.astro';
import { absoluteUrl, site } from '../../data/business';
import { breadcrumbList, webPage } from '../../data/schema';

const areas = await getCollection('serviceAreas', ({ data }) => data.published === true);
areas.sort((a, b) => a.data.title.localeCompare(b.data.title));

const areaCards = areas.map((entry) => ({
  title: entry.data.title,
  description: entry.data.summary,
  href: `/service-areas/${entry.data.slug}/`,
  footerText: 'View area →',
  headingLevel: 2 as const,
}));

const title = `Service Areas | ${site.name}`;
const description =
  'Handyman service areas in Katy, West Houston, and surrounding master-planned communities.';
const canonical = absoluteUrl('/service-areas/');

const schemaGraph = [
  webPage('Service Areas', canonical, description),
  breadcrumbList([
    { name: 'Home', url: absoluteUrl('/') },
    { name: 'Service Areas', url: canonical },
  ]),
];
---

<ContentLayout seo={{ title, description, canonical }} schemaGraph={schemaGraph}>
  <article>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-12">
    <BreadcrumbNav
      items={[
        { name: 'Home', url: '/' },
        { name: 'Service Areas', url: '/service-areas/' },
      ]}
    />
    <h1 class="text-4xl md:text-5xl font-extrabold text-brand-black mb-6 mt-6">Service Areas</h1>
    <p class="text-lg text-gray-600 mb-10 max-w-3xl">
      Elevate Your Space Handyman serves homeowners throughout Katy and West Houston.
    </p>
    {
      areaCards.length > 0 ? (
        <BalancedGrid variant="card" items={areaCards} cols={3} gapClass="gap-6" />
      ) : (
        <p class="text-gray-600">
          Service area pages will be listed here as local content is added.
        </p>
      )
    }
  </div>
  <LocalAreaCTA locationName="Katy & West Houston" />
  </article>
</ContentLayout>
