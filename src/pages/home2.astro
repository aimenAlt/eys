---
/**
 * Preview route for the previous homepage variant (HomeCurrentPage).
 * Open at /home2/ — noindex; canonical points to `/`.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileStickyCTA from '../components/layout/MobileStickyCTA.astro';
import HomeCurrentPage from '../components/home/HomeCurrentPage.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl } from '../data/business';
import { homePageSchema, homeFaqs } from '../data/schema';
import { buildNavMenus } from '../data/navMenus';

const [publishedReviews, allServices, serviceAreas, communities] = await Promise.all([
  getCollection('reviews', ({ data }) => data.published === true),
  getCollection('services'),
  getCollection('serviceAreas', ({ data }) => data.published === true),
  getCollection('communities', ({ data }) => data.published === true),
]);

const navMenus = buildNavMenus(allServices, serviceAreas, communities);

const cityLinks = serviceAreas.map((a) => ({ title: a.data.title, slug: a.data.slug }));
const communityLinks = communities.map((c) => ({
  title: c.data.title,
  citySlug: c.data.citySlug,
  slug: c.data.slug,
}));

const seo = {
  title: 'Classic Homepage Preview | Elevate Your Space',
  description:
    'Internal preview of the classic homepage layout. The live site homepage is at the root URL.',
  canonical: absoluteUrl('/'),
  noindex: true,
};

const schemaGraph = homePageSchema(
  homeFaqs,
  publishedReviews.map((r) => r.data),
);
---

<BaseLayout seo={seo} schemaGraph={schemaGraph}>
  <Header navMenus={navMenus} />
  <main id="main-content">
    <HomeCurrentPage
      projectCount={communities.length}
      publishedReviews={publishedReviews}
      cityLinks={cityLinks}
      communityLinks={communityLinks}
    />
  </main>
  <Footer />
  <MobileStickyCTA />
</BaseLayout>
