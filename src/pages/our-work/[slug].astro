---
import { render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import BreadcrumbNav from '../../components/seo/BreadcrumbNav.astro';
import CTASection from '../../components/home/CTASection.astro';
import BeforeAfter from '../../components/projects/BeforeAfter.astro';
import ProjectCard from '../../components/projects/ProjectCard.astro';
import ProjectCTA from '../../components/projects/ProjectCTA.astro';
import { absoluteUrl, site } from '../../data/business';
import { breadcrumbList, webPage } from '../../data/schema';
import { projectCategoryLabel } from '../../data/projectCategories';
import {
  getLiveProjects,
  projectHref,
  projectLocationLabel,
  relatedProjects,
} from '../../data/projects';
import { imageOrPlaceholder } from '../../data/images';

export async function getStaticPaths() {
  const projects = await getLiveProjects();
  return projects.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const all = await getLiveProjects();
const related = relatedProjects(entry, all, 3);

const categoryLabel = projectCategoryLabel(data.category);
const location = projectLocationLabel(data);
const title =
  data.seoTitle ||
  (location ? `${data.title} in ${data.city || location} | ${site.shortName} Handyman` : `${data.title} | ${site.shortName} Handyman`);
const description = data.metaDescription || data.summary;
const canonical = absoluteUrl(projectHref(data.slug));
const h1 = location && data.city ? `${data.title} in ${data.city}` : data.title;

const crumbs = [
  { name: 'Home', url: absoluteUrl('/') },
  { name: 'Our Work', url: absoluteUrl('/our-work/') },
  { name: data.title, url: canonical },
];

const schemaGraph = [webPage(title, canonical, description), breadcrumbList(crumbs)];

const supporting = data.images.filter((img) => img.src !== data.leadImage);
---

<ContentLayout seo={{ title, description, canonical }} schemaGraph={schemaGraph}>
  <article>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <BreadcrumbNav
        items={[
          { name: 'Home', url: '/' },
          { name: 'Our Work', url: '/our-work/' },
          { name: data.title, url: projectHref(data.slug) },
        ]}
      />
    </div>

    <header class="bg-brand-lightbg border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-12">
        <p class="text-brand-red font-bold text-sm tracking-widest uppercase mb-2">{categoryLabel}</p>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-brand-black tracking-tight mb-3">
          {h1}
        </h1>
        {
          location && (
            <p class="text-lg text-gray-600 mb-4">{location}</p>
          )
        }
        <p class="text-lg text-gray-600 max-w-3xl leading-relaxed">{data.summary}</p>
      </div>
    </header>

    <section class="py-10 md:py-14 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <figure class="m-0 overflow-hidden rounded-2xl ring-1 ring-brand-line shadow-card bg-gray-100">
          <img
            src={imageOrPlaceholder(data.leadImage)}
            alt={data.leadAlt}
            width="1200"
            height="900"
            fetchpriority="high"
            decoding="async"
            class="w-full aspect-[4/3] object-cover"
          />
        </figure>
      </div>
    </section>

    {
      data.beforeAfter && (
        <section class="py-10 bg-brand-lightbg border-y border-brand-line">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <BeforeAfter
              beforeImage={data.beforeAfter.beforeImage}
              beforeAlt={data.beforeAfter.beforeAlt}
              afterImage={data.beforeAfter.afterImage}
              afterAlt={data.beforeAfter.afterAlt}
              angleMatch={data.beforeAfter.angleMatch}
            />
          </div>
        </section>
      )
    }

    {
      supporting.length > 0 && (
        <section class="py-12 md:py-16 bg-white" aria-labelledby="project-photos-heading">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 id="project-photos-heading" class="text-2xl md:text-3xl font-bold text-brand-black mb-8">
              Project Photos
            </h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6 list-none p-0 m-0">
              {supporting.map((img) => (
                <li>
                  <figure class="m-0 overflow-hidden rounded-xl ring-1 ring-brand-line shadow-card bg-gray-100">
                    <img
                      src={imageOrPlaceholder(img.src)}
                      alt={img.alt}
                      width="800"
                      height="600"
                      loading="lazy"
                      decoding="async"
                      class="w-full aspect-[4/3] object-cover"
                    />
                    {(img.caption || img.stage) && (
                      <figcaption class="p-4 text-sm text-gray-600 bg-white">
                        {img.stage && (
                          <span class="text-xs font-bold uppercase text-brand-red mr-2">{img.stage}</span>
                        )}
                        {img.caption}
                      </figcaption>
                    )}
                  </figure>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }

    {
      data.scope && data.scope.length > 0 && (
        <section class="py-12 bg-brand-lightbg border-y border-brand-line" aria-labelledby="project-scope-heading">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 id="project-scope-heading" class="text-2xl font-bold text-brand-black mb-4">
              Project Scope
            </h2>
            <ul class="list-disc pl-5 space-y-2 text-gray-700 max-w-2xl">
              {data.scope.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </section>
      )
    }

    <section class="py-12 md:py-14 bg-white border-t border-brand-line" aria-labelledby="project-story-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="project-story-heading" class="text-2xl md:text-3xl font-bold text-brand-black mb-6">
          Project Details
        </h2>
        <div class="prose prose-gray max-w-3xl">
          <Content />
        </div>
      </div>
    </section>

    <section class="py-12 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row flex-wrap gap-3 mb-10">
          {
            data.serviceUrl && (
              <a
                href={data.serviceUrl}
                class="inline-flex items-center justify-center border-2 border-brand-black px-6 py-3 rounded-md font-bold min-h-11 hover:bg-brand-black hover:text-white transition-colors"
              >
                Related: {categoryLabel} services
              </a>
            )
          }
          <a
            href="/our-work/"
            class="inline-flex items-center justify-center text-brand-red font-bold px-2 py-3 min-h-11"
          >
            ← Back to Our Work
          </a>
        </div>
        <ProjectCTA
          heading="Need something like this?"
          body="Request an estimate with a few photos of your project and we will follow up about next steps."
          ctaLocation="project-detail"
        />
      </div>
    </section>

    {
      related.length > 0 && (
        <section class="py-14 bg-brand-lightbg border-t border-brand-line" aria-labelledby="related-projects-heading">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 id="related-projects-heading" class="text-2xl md:text-3xl font-bold text-brand-black mb-8">
              Related Projects
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {related.map((project) => (
                <ProjectCard project={project} />
              ))}
            </div>
          </div>
        </section>
      )
    }

    <CTASection />
  </article>
</ContentLayout>
