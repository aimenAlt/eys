---
import ContentLayout from '../layouts/ContentLayout.astro';
import { absoluteUrl, site } from '../data/business';

const title = `Page Not Found | ${site.name}`;
const description = 'The page you are looking for could not be found.';
const canonical = absoluteUrl('/404/');
---

<ContentLayout seo={{ title, description, canonical, noindex: true }}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-brand-red font-bold text-sm uppercase tracking-widest mb-4">404</p>
    <h1 class="text-4xl font-extrabold text-brand-black mb-4">Page not found</h1>
    <p class="text-gray-600 mb-8">Sorry, we couldn't find that page. Try one of the links below.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/" class="inline-block bg-brand-red text-white px-6 py-3 rounded-md font-bold hover:bg-brand-redhover transition-colors">Go Home</a>
      <a href="/services/" class="inline-block border-2 border-brand-black text-brand-black px-6 py-3 rounded-md font-bold hover:bg-brand-black hover:text-white transition-colors">Our Services</a>
      <a href="/service-areas/" class="inline-block border-2 border-brand-black text-brand-black px-6 py-3 rounded-md font-bold hover:bg-brand-black hover:text-white transition-colors">Service Areas</a>
      <a href="/contact/" class="inline-block border-2 border-brand-black text-brand-black px-6 py-3 rounded-md font-bold hover:bg-brand-black hover:text-white transition-colors">Contact</a>
    </div>
  </div>
</ContentLayout>
