---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { absoluteUrl, site } from '../../data/business';

const services = await getCollection('services', ({ data }) => data.published === true);

const title = `Handyman Services | ${site.name}`;
const description =
  'Professional handyman services in Katy and West Houston. TV mounting, drywall, painting, door repair, and more.';
const canonical = absoluteUrl('/services/');
---

<ContentLayout seo={{ title, description, canonical }}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl md:text-5xl font-extrabold text-brand-black mb-6">Our Services</h1>
    <p class="text-lg text-gray-600 mb-12 max-w-3xl">
      Reliable handyman services for Katy and West Houston homeowners.
    </p>
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        services.map((entry) => (
          <li>
            <a
              href={`/services/${entry.data.slug}/`}
              class="block h-full p-6 bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:border-brand-red/30 transition-all"
            >
              <h2 class="text-xl font-bold text-brand-black mb-2">{entry.data.title}</h2>
              {entry.data.summary && (
                <p class="text-sm text-gray-600">{entry.data.summary}</p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</ContentLayout>
