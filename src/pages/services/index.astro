---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import BreadcrumbNav from '../../components/seo/BreadcrumbNav.astro';
import BalancedGrid from '../../components/ui/BalancedGrid.astro';
import { absoluteUrl, site } from '../../data/business';
import { breadcrumbList, webPage } from '../../data/schema';
import { serviceCategories } from '../../data/serviceCategories';

const services = await getCollection('services', ({ data }) => data.published === true);
services.sort((a, b) => a.data.title.localeCompare(b.data.title));

const serviceCards = services.map((entry) => ({
  title: entry.data.title,
  description: entry.data.summary,
  href: `/services/${entry.data.slug}/`,
}));

const title = `Handyman Services | ${site.name}`;
const description =
  '13 handyman services in Katy and West Houston — repairs, installation, and remodeling. Browse by category or explore TV mounting, electrical, drywall, painting, and more.';
const canonical = absoluteUrl('/services/');

const schemaGraph = [
  webPage('Our Services', canonical, description),
  breadcrumbList([
    { name: 'Home', url: absoluteUrl('/') },
    { name: 'Services', url: canonical },
  ]),
];
---

<ContentLayout seo={{ title, description, canonical }} schemaGraph={schemaGraph}>
  <article>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <BreadcrumbNav
      items={[
        { name: 'Home', url: '/' },
        { name: 'Services', url: '/services/' },
      ]}
    />
    <h1 class="text-4xl md:text-5xl font-extrabold text-brand-black mb-6 mt-6">Our Services</h1>
    <p class="text-lg text-gray-600 mb-12 max-w-3xl">
      Reliable handyman services for Katy and West Houston homeowners.
    </p>

    <section class="mb-16" aria-labelledby="service-categories">
      <h2 id="service-categories" class="text-2xl font-bold text-brand-black mb-6">Browse by category</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          serviceCategories.map((category) => (
            <a
              href={`/services/${category.slug}/`}
              class="block h-full p-6 bg-brand-black text-white rounded-xl shadow-sm hover:shadow-md transition-all group"
            >
              <h3 class="text-xl font-bold mb-2">{category.title}</h3>
              <p class="text-sm text-gray-300 mb-4">{category.summary}</p>
              <span class="text-sm font-bold text-brand-red group-hover:underline">{category.ctaLabel} →</span>
            </a>
          ))
        }
      </div>
    </section>

    <h2 class="text-2xl font-bold text-brand-black mb-6">All services</h2>
    <BalancedGrid variant="card" items={serviceCards} cols={3} gapClass="gap-6" />
  </div>
  </article>
</ContentLayout>
