---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import HomeHero from '../components/home/HomeHero.astro';
import TrustBar from '../components/home/TrustBar.astro';
import ServiceGrid from '../components/home/ServiceGrid.astro';
import CTASection from '../components/home/CTASection.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout>
    <Header />
    <HomeHero />
    <TrustBar />
    <!-- 4. "Who We Are" Section -->
    <section id="about" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
                
                <!-- Left: Content -->
                <div class="mb-12 lg:mb-0">
                    <h4 class="text-brand-red font-bold text-sm tracking-widest uppercase mb-2">Who We Are</h4>
                    <h2 class="text-3xl md:text-4xl font-bold text-brand-black mb-6">NO.1 Handyman Service In Katy</h2>
                    <p class="text-gray-600 mb-8 leading-relaxed">
                        Some names just stay in your mind. When something needs to be done right, you do not think twice. There is a reason people keep coming back, a reason the name carries weight. It is not about words or promises, it is about how it feels when the job is done and the space finally makes sense. In Katy, one service keeps that feeling alive, every single time.
                    </p>

                    <div class="space-y-6">
                        <div class="flex">
                            <div class="flex-shrink-0 mt-1">
                                <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                            <div class="ml-4">
                                <h3 class="text-lg font-bold text-brand-black">Building Trust</h3>
                                <p class="text-sm text-gray-600 mt-1">For each and every one of our projects, we maintain the highest standards of honesty, professionalism, and quality, which guarantees first rate outcomes and happy clients.</p>
                            </div>
                        </div>
                        <div class="flex">
                            <div class="flex-shrink-0 mt-1">
                                <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            </div>
                            <div class="ml-4">
                                <h3 class="text-lg font-bold text-brand-black">Experienced professionals</h3>
                                <p class="text-sm text-gray-600 mt-1">Delivering dependable handyman, repair, and home improvement services with a strong focus on safety and customer satisfaction.</p>
                            </div>
                        </div>
                        <div class="flex">
                            <div class="flex-shrink-0 mt-1">
                                <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            </div>
                            <div class="ml-4">
                                <h3 class="text-lg font-bold text-brand-black">Ensuring Quality</h3>
                                <p class="text-sm text-gray-600 mt-1">Dedicated to improving homes through skilled, reliable, and detail-focused repair, installation, and remodeling solutions.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Images (Overlapping) -->
                <div class="relative h-80 sm:h-96 lg:h-[500px] mt-10 lg:mt-0">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=600" loading="lazy" class="absolute top-0 right-0 w-4/5 h-[75%] object-cover rounded-xl shadow-xl z-10 border-4 border-white" alt="Wall and fireplace feature project in Katy">
                    <img src="https://images.unsplash.com/photo-1556910103-1c02745a872e?auto=format&fit=crop&q=80&w=600" loading="lazy" class="absolute bottom-0 left-0 w-3/4 h-[70%] object-cover rounded-xl shadow-2xl z-20 border-4 border-white" alt="Kitchen cabinet remodeling in Texas">
                </div>

            </div>
        </div>
    </section>

    <!-- 5. Value Proposition Section -->
    <section class="py-16 bg-brand-lightbg border-y border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-10">
                <h4 class="text-brand-red font-bold text-sm tracking-widest uppercase">Our Value</h4>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Card 1 -->
                <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mb-6 text-brand-red">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-brand-black mb-3">Experienced Handyman</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">Reliable, skilled, and always ready, our experienced handyman brings confidence to every task, big or small.</p>
                </div>
                <!-- Card 2 -->
                <div class="bg-brand-black p-8 rounded-xl shadow-sm text-white hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center mb-6 text-white">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Discounted Prices</h3>
                    <p class="text-gray-300 text-sm leading-relaxed">Fair pricing that respects your budget gets the help you need without the stress of high costs or surprise fees.</p>
                </div>
                <!-- Card 3 -->
                <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mb-6 text-brand-red">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-brand-black mb-3">Reliable Result You Can Trust</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">Consistency, care, and peace expect results that meet your standards and leave no room for second guessing.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 6. Dedicated SEO Content Section -->
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                <!-- Text Column -->
                <div class="lg:col-span-8">
                    <h2 class="text-3xl font-bold text-brand-black mb-6">Home Repair & Remodeling Services in Katy, TX</h2>
                    <p class="text-gray-600 mb-4 leading-relaxed">
                        Elevate Your Space Handyman helps homeowners in Katy, Texas complete repairs, improvements, installations, and small remodeling projects with confidence. Whether the job is a drywall patch, door installation, bathroom update, cabinet improvement, painting project, flooring upgrade, or general home repair, our team focuses on honest communication, clean workmanship, and dependable results.
                    </p>
                    <p class="text-gray-600 leading-relaxed">
                        We proudly serve homeowners throughout Katy and surrounding areas, helping with both quick fixes and larger home improvement projects. From minor repairs to complete upgrades, our goal is simple: make your space safer, cleaner, more functional, and more comfortable.
                    </p>
                </div>
                <!-- Checklist Column -->
                <div class="lg:col-span-4 bg-brand-lightbg p-6 rounded-xl border border-gray-200">
                    <h3 class="font-bold text-brand-black mb-4">Common projects we handle include:</h3>
                    <ul class="space-y-2 text-sm text-gray-700">
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>General handyman services</li>
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Bathroom remodeling</li>
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Kitchen remodeling</li>
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Drywall repair and finishing</li>
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Door installation</li>
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Custom cabinets</li>
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Furniture installation</li>
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>House painting</li>
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Electrical work</li>
                        <li class="flex items-start"><svg class="w-5 h-5 text-brand-red mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Flooring and decor upgrades</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
    <ServiceGrid />
    <!-- 8. Why Choose Us? Section -->
    <section class="relative py-24 bg-brand-black">
        <div class="absolute inset-0 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&q=80&w=1920" loading="lazy" class="w-full h-full object-cover opacity-20" alt="Construction Blueprint Background">
        </div>
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
            <div class="text-center mb-16">
                <h4 class="text-brand-red font-bold text-sm tracking-widest uppercase mb-2">Why Choose Us</h4>
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Why Choose Us?</h2>
                <p class="text-gray-300">The following points show our commitment to excellence</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-white/10 backdrop-blur-md border border-white/20 p-8 rounded-xl text-white">
                    <div class="w-12 h-12 bg-brand-red rounded-full flex items-center justify-center mb-6">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Skilled and trusted team</h3>
                    <p class="text-gray-300 text-sm">Experienced professionals who treat every project with care, precision, and accountability.</p>
                </div>

                <div class="bg-brand-red border border-red-700 p-8 rounded-xl text-white shadow-lg transform md:-translate-y-4">
                    <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mb-6">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Affordable Pricing</h3>
                    <p class="text-red-100 text-sm">Fair, transparent pricing designed to respect your budget without surprise fees.</p>
                </div>

                <div class="bg-white/10 backdrop-blur-md border border-white/20 p-8 rounded-xl text-white">
                    <div class="w-12 h-12 bg-brand-red rounded-full flex items-center justify-center mb-6">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Right on time</h3>
                    <p class="text-gray-300 text-sm">Dependable scheduling, clear communication, and work completed with steady professionalism.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 9. Recent Projects / Gallery Preview -->
    <section id="gallery" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-12">
                <div class="max-w-2xl">
                    <h2 class="text-3xl font-bold text-brand-black mb-4">Recent Projects</h2>
                    <p class="text-gray-600">See examples of repair, installation, and remodeling work completed for local homeowners.</p>
                </div>
                <a href="#" class="hidden md:inline-block mt-4 md:mt-0 text-brand-red font-bold hover:underline">View Gallery &rarr;</a>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                <div class="aspect-w-1 aspect-h-1 overflow-hidden rounded-lg bg-gray-100">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=400" loading="lazy" class="object-cover w-full h-full hover:scale-105 transition-transform duration-300" alt="TV Fireplace Wall">
                </div>
                <div class="aspect-w-1 aspect-h-1 overflow-hidden rounded-lg bg-gray-100">
                    <img src="https://images.unsplash.com/photo-1556910103-1c02745a872e?auto=format&fit=crop&q=80&w=400" loading="lazy" class="object-cover w-full h-full hover:scale-105 transition-transform duration-300" alt="Kitchen Remodel">
                </div>
                <div class="aspect-w-1 aspect-h-1 overflow-hidden rounded-lg bg-gray-100">
                    <img src="https://images.unsplash.com/photo-1620626011761-996317b8d101?auto=format&fit=crop&q=80&w=400" loading="lazy" class="object-cover w-full h-full hover:scale-105 transition-transform duration-300" alt="Bathroom Upgrade">
                </div>
                <div class="aspect-w-1 aspect-h-1 overflow-hidden rounded-lg bg-gray-100">
                    <img src="https://images.unsplash.com/photo-1581858326451-b8be354be432?auto=format&fit=crop&q=80&w=400" loading="lazy" class="object-cover w-full h-full hover:scale-105 transition-transform duration-300" alt="Flooring Work">
                </div>
                <div class="aspect-w-1 aspect-h-1 overflow-hidden rounded-lg bg-gray-100">
                    <img src="https://images.unsplash.com/photo-1505691938895-1758d7feb511?auto=format&fit=crop&q=80&w=400" loading="lazy" class="object-cover w-full h-full hover:scale-105 transition-transform duration-300" alt="Door and Trim Installation">
                </div>
                <div class="aspect-w-1 aspect-h-1 overflow-hidden rounded-lg bg-gray-100">
                    <img src="https://images.unsplash.com/photo-1589939705384-5185137a7f0f?auto=format&fit=crop&q=80&w=400" loading="lazy" class="object-cover w-full h-full hover:scale-105 transition-transform duration-300" alt="House Painting">
                </div>
            </div>
            
            <div class="mt-8 text-center md:hidden">
                <a href="#" class="inline-block py-3 px-6 border border-brand-red text-brand-red font-bold rounded hover:bg-brand-red hover:text-white transition-colors">View Gallery</a>
            </div>
        </div>
    </section>

    <!-- 10. Process Section (How It Works) -->
    <section class="py-20 bg-brand-lightbg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h4 class="text-brand-red font-bold text-sm tracking-widest uppercase mb-2">How It Works</h4>
                <h2 class="text-3xl md:text-4xl font-bold text-brand-black">Simple Steps to Elevate Your Space</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Step 1 -->
                <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm relative">
                    <div class="text-5xl font-extrabold text-gray-100 absolute top-4 right-4">01</div>
                    <div class="relative z-10">
                        <h3 class="text-lg font-bold text-brand-black mb-3 mt-4">Consultation</h3>
                        <p class="text-sm text-gray-600">Get in touch with us so we can go over your project details and provide you with our professional opinion.</p>
                    </div>
                </div>
                <!-- Step 2 -->
                <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm relative">
                    <div class="text-5xl font-extrabold text-gray-100 absolute top-4 right-4">02</div>
                    <div class="relative z-10">
                        <h3 class="text-lg font-bold text-brand-black mb-3 mt-4">Estimate</h3>
                        <p class="text-sm text-gray-600">Receive a detailed, transparent quote tailored to your needs and budget.</p>
                    </div>
                </div>
                <!-- Step 3 -->
                <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm relative">
                    <div class="text-5xl font-extrabold text-gray-100 absolute top-4 right-4">03</div>
                    <div class="relative z-10">
                        <h3 class="text-lg font-bold text-brand-black mb-3 mt-4">Execution</h3>
                        <p class="text-sm text-gray-600">Our skilled team completes the work efficiently and with the highest quality standards.</p>
                    </div>
                </div>
                <!-- Step 4 -->
                <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm relative">
                    <div class="text-5xl font-extrabold text-gray-100 absolute top-4 right-4">04</div>
                    <div class="relative z-10">
                        <h3 class="text-lg font-bold text-brand-black mb-3 mt-4">Final Review</h3>
                        <p class="text-sm text-gray-600">We ensure your complete satisfaction before considering the job done.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 11. Reviews Section -->
    <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <h4 class="text-brand-red font-bold text-sm tracking-widest uppercase mb-2">Testimonials</h4>
                <h2 class="text-3xl md:text-4xl font-bold text-brand-black mb-4">Our Customers Reviews</h2>
                <div class="inline-flex items-center bg-gray-50 rounded-full px-4 py-2 border border-gray-200">
                    <span class="font-bold text-brand-black mr-2">Elevate Your Space Handyman</span>
                    <div class="flex text-yellow-400 mr-2">
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
