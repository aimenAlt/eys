---
import { getCollection } from 'astro:content';
import ContentLayout from '../layouts/ContentLayout.astro';
import PageHero from '../components/common/PageHero.astro';
import BreadcrumbNav from '../components/seo/BreadcrumbNav.astro';
import CTASection from '../components/home/CTASection.astro';
import BalancedGrid from '../components/ui/BalancedGrid.astro';
import { absoluteUrl, site } from '../data/business';
import { reviewsPageSchema } from '../data/schema';

const reviews = await getCollection('reviews', ({ data }) => data.published === true);
reviews.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const reviewItems = reviews.map((entry) => ({
  author: entry.data.author,
  rating: entry.data.rating,
  text: entry.data.text,
  source: entry.data.source,
  date: entry.data.date,
  location: entry.data.location,
}));

const title = `Customer Reviews | ${site.name}`;
const description =
  'Read verified customer reviews for Elevate Your Space Handyman in Katy and West Houston. 4.9 stars from 150+ Google reviews.';
const canonical = absoluteUrl('/reviews/');

const schemaGraph = reviewsPageSchema(
  canonical,
  description,
  reviewItems.map((r) => ({
    author: r.author,
    rating: r.rating,
    text: r.text,
    date: r.date,
  })),
);
---

<ContentLayout seo={{ title, description, canonical }} schemaGraph={schemaGraph}>
  <article>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <BreadcrumbNav
        items={[
          { name: 'Home', url: '/' },
          { name: 'Reviews', url: '/reviews/' },
        ]}
      />
    </div>

    <PageHero
      eyebrow="Customer Feedback"
      title="What West Houston Homeowners Say"
      description="Featured reviews from homeowners we have worked with across Katy and West Houston. Elevate Your Space holds a 4.9-star average from 150+ Google reviews."
    />

    <section class="py-10 bg-brand-lightbg border-y border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-gray-700 max-w-3xl leading-relaxed mb-4">
          Ratings shown on this page reflect our Google review aggregate (4.9 stars from 150+ reviews). The testimonials below are featured examples from local homeowners — not our full review history.
        </p>
        <p class="text-gray-700 max-w-3xl leading-relaxed">
          Looking for the kind of work people review us for? Explore{' '}
          <a href="/services/tv-mounting/" class="text-brand-red font-bold hover:underline">TV mounting</a>,{' '}
          <a href="/services/general-handyman-services/" class="text-brand-red font-bold hover:underline">general handyman services</a>, and{' '}
          <a href="/services/ceiling-fan-installation/" class="text-brand-red font-bold hover:underline">ceiling fan installation</a>. Serving{' '}
          <a href="/service-areas/katy/" class="text-brand-red font-bold hover:underline">Katy</a>,{' '}
          <a href="/service-areas/cypress/" class="text-brand-red font-bold hover:underline">Cypress</a>,{' '}
          <a href="/service-areas/fulshear/" class="text-brand-red font-bold hover:underline">Fulshear</a>,{' '}
          <a href="/service-areas/richmond/" class="text-brand-red font-bold hover:underline">Richmond</a>, and{' '}
          <a href="/service-areas/west-houston/" class="text-brand-red font-bold hover:underline">West Houston</a>.
        </p>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {
          reviewItems.length > 0 ? (
            <BalancedGrid variant="review" items={reviewItems} cols={3} gapClass="gap-6" />
          ) : (
            <p class="text-gray-600 max-w-2xl">
              Verified customer reviews will appear here as they are added. Contact us to share your experience or ask about recent work in your area.
            </p>
          )
        }
      </div>
    </section>

    <CTASection />
  </article>
</ContentLayout>
