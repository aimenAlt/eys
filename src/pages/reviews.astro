---
import { getCollection } from 'astro:content';
import ContentLayout from '../layouts/ContentLayout.astro';
import PageHero from '../components/common/PageHero.astro';
import BreadcrumbNav from '../components/seo/BreadcrumbNav.astro';
import CTASection from '../components/home/CTASection.astro';
import BalancedGrid from '../components/ui/BalancedGrid.astro';
import { absoluteUrl, site } from '../data/business';
import { reviewsPageSchema } from '../data/schema';

const reviews = await getCollection('reviews', ({ data }) => data.published === true);
reviews.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const reviewItems = reviews.map((entry) => ({
  author: entry.data.author,
  rating: entry.data.rating,
  text: entry.data.text,
  source: entry.data.source,
  date: entry.data.date,
  location: entry.data.location,
}));

const title = `Customer Reviews | ${site.name}`;
const description =
  'Read verified customer reviews for Elevate Your Space Handyman in Katy and West Houston. 4.9 stars from 150+ Google reviews.';
const canonical = absoluteUrl('/reviews/');

const schemaGraph = reviewsPageSchema(
  canonical,
  description,
  reviewItems.map((r) => ({
    author: r.author,
    rating: r.rating,
    text: r.text,
    date: r.date,
  })),
);
---

<ContentLayout seo={{ title, description, canonical }} schemaGraph={schemaGraph}>
  <article>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <BreadcrumbNav
        items={[
          { name: 'Home', url: '/' },
          { name: 'Reviews', url: '/reviews/' },
        ]}
      />
    </div>

    <PageHero
      eyebrow="Customer Feedback"
      title="Reviews"
      description="Verified reviews from homeowners we have worked with in Katy and West Houston."
    />

    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {
          reviewItems.length > 0 ? (
            <BalancedGrid variant="review" items={reviewItems} cols={3} gapClass="gap-6" />
          ) : (
            <p class="text-gray-600 max-w-2xl">
              Verified customer reviews will appear here as they are added. Contact us to share your experience or ask about recent work in your area.
            </p>
          )
        }
      </div>
    </section>

    <CTASection />
  </article>
</ContentLayout>
