---
import { jobberHandymanToDoListFormUrl, site } from '../../../data/business';
import { handymanToDoListVisitName } from '../../../data/smallRepairVisitContent';

const bookUrl = jobberHandymanToDoListFormUrl();
---

<section
  id="book-visit"
  class="py-16 md:py-20 bg-white border-t border-brand-line"
  aria-labelledby="book-heading"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-brand-red font-bold text-xs tracking-widest uppercase mb-2">Book online</p>
    <h2 id="book-heading" class="text-3xl font-bold text-brand-black mb-3">
      Ready to book your {handymanToDoListVisitName}?
    </h2>
    <p class="text-gray-600 leading-relaxed max-w-xl mx-auto mb-8">
      Open our booking form to choose a visit length, share your task list and photos, and request a
      time that works for you.
    </p>
    {
      bookUrl ? (
        <a
          href={bookUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="gradient-btn inline-flex items-center justify-center text-white px-8 py-3.5 rounded-md font-bold shadow-lg hover:shadow-xl transition-all"
          data-cta="handyman-to-do-list-book"
        >
          Book a Handyman Visit
        </a>
      ) : (
        <a
          href="/contact/"
          class="gradient-btn inline-flex items-center justify-center text-white px-8 py-3.5 rounded-md font-bold shadow-lg hover:shadow-xl transition-all"
        >
          Contact us to book
        </a>
      )
    }
    <p class="mt-6 text-sm text-gray-500">
      Prefer to talk first? Call{' '}
      <a href={`tel:${site.phoneTel}`} class="font-semibold text-brand-red hover:underline">
        {site.phone}
      </a>
    </p>
  </div>
</section>

<script>
  import { analyticsEvents, trackEvent } from '../../../utils/analytics';

  document.querySelectorAll<HTMLAnchorElement>('[data-cta="handyman-to-do-list-book"]').forEach((link) => {
    link.addEventListener('click', () => {
      trackEvent(analyticsEvents.jobberFallbackClick, {
        form: 'handyman_to_do_list',
      });
    });
  });
</script>
