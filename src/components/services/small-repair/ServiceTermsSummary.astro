---
import {
  serviceTermsDetails,
  serviceTermsSummary,
} from '../../../data/smallRepairVisitContent';
---

<section id="service-terms" class="py-16 md:py-20 bg-brand-lightbg" aria-labelledby="terms-heading">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="terms-heading" class="text-3xl font-bold text-brand-black mb-3 text-center">
      Important Service Terms
    </h2>
    <p class="text-gray-600 text-center mb-10">
      Clear expectations so your visit goes smoothly.
    </p>
    <ul class="space-y-3 mb-6">
      {
        serviceTermsSummary.map((term) => (
          <li class="flex items-start gap-3 bg-white rounded-lg border border-brand-line p-4 text-sm text-gray-700">
            <svg
              class="w-5 h-5 text-brand-red mt-0.5 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>{term}</span>
          </li>
        ))
      }
    </ul>
    <details class="bg-white rounded-lg border border-brand-line group">
      <summary class="font-bold p-5 text-brand-black cursor-pointer list-none flex justify-between items-center">
        Additional policy details
        <span class="text-brand-red transition group-open:rotate-180" aria-hidden="true">
          <svg fill="none" height="20" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="20">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </span>
      </summary>
      <ul class="px-5 pb-5 space-y-2 text-sm text-gray-600">
        {
          serviceTermsDetails.map((detail) => (
            <li class="leading-relaxed">{detail}</li>
          ))
        }
        <li class="leading-relaxed">
          See also our{' '}
          <a href="/terms/" class="text-brand-red font-semibold hover:underline">Terms of Service</a>.
        </li>
      </ul>
    </details>
  </div>
</section>
