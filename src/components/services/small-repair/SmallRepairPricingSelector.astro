---
import {
  additionalTimeLabel,
  formatDurationLabel,
  visitDurationOptions,
} from '../../../data/smallRepairPricing';

const defaultOption = visitDurationOptions.find((o) => o.hours === 2) ?? visitDurationOptions[0];
const priceMap = Object.fromEntries(
  visitDurationOptions.map((o) => [String(o.hours), o.priceFormatted]),
);
---

<section id="pricing" class="py-16 md:py-20 bg-brand-lightbg" aria-labelledby="pricing-heading">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="pricing-heading" class="text-3xl font-bold text-brand-black mb-3 text-center">
      Choose Your Visit Length
    </h2>
    <p class="text-gray-600 text-center mb-10 max-w-xl mx-auto">
      Select a labor duration. The price shown is for handyman labor only — materials and specialty
      equipment are additional unless specifically included.
    </p>

    <div
      class="bg-white rounded-xl border border-brand-line shadow-card p-6 md:p-8"
      data-pricing-selector
      data-price-map={JSON.stringify(priceMap)}
    >
      <fieldset>
        <legend class="sr-only">Visit duration</legend>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" role="radiogroup" aria-labelledby="pricing-heading">
          {
            visitDurationOptions.map((option) => (
              <label
                class:list={[
                  'flex items-center justify-between gap-3 rounded-lg border px-4 py-3 cursor-pointer transition-colors',
                  'has-[:checked]:border-brand-red has-[:checked]:bg-brand-redsoft has-[:checked]:ring-1 has-[:checked]:ring-brand-red/30',
                  'border-brand-line hover:border-gray-300',
                ]}
              >
                <span class="flex items-center gap-3">
                  <input
                    type="radio"
                    name="visit-duration"
                    value={String(option.hours)}
                    class="accent-brand-red w-4 h-4"
                    checked={option.hours === defaultOption.hours}
                    data-duration-hours={option.hours}
                    data-duration-label={formatDurationLabel(option.hours)}
                    data-duration-price={option.priceFormatted}
                  />
                  <span class="font-semibold text-brand-black">{option.label}</span>
                </span>
                <span class="font-bold text-brand-black tabular-nums">{option.priceFormatted}</span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <div
        class="mt-6 rounded-lg bg-brand-lightbg border border-brand-line p-5"
        data-price-summary
        aria-live="polite"
      >
        <h3 class="text-sm font-bold uppercase tracking-wide text-brand-muted mb-3">
          Pricing summary
        </h3>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between gap-4">
            <dt class="text-gray-600">Selected visit</dt>
            <dd class="font-semibold text-brand-black" data-summary-duration>
              {formatDurationLabel(defaultOption.hours)}
            </dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-gray-600">Labor price</dt>
            <dd class="font-extrabold text-brand-black text-lg tabular-nums" data-summary-price>
              {defaultOption.priceFormatted}
            </dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-gray-600">Materials</dt>
            <dd class="font-semibold text-brand-black">Additional when required</dd>
          </div>
        </dl>
      </div>

      <p class="mt-4 text-sm text-gray-600 leading-relaxed">
        Additional time after your reserved block is performed only with your approval ({additionalTimeLabel}{' '}
        after two hours). Completion of every submitted task is not guaranteed within the selected
        duration.
      </p>

      <p class="mt-4 text-sm text-gray-600">
        Need more than four hours?{' '}
        <a href="/contact/" class="font-semibold text-brand-red hover:underline">
          Request a custom full-day or project estimate
        </a>.
      </p>

      <a
        href="#request-form"
        class="mt-6 gradient-btn text-white px-8 py-3.5 rounded-md font-bold text-center transition-all shadow-lg hover:shadow-xl block w-full sm:w-auto sm:inline-block"
        data-request-cta
      >
        Continue to Request Form
      </a>

      <!--
        TODO: Jobber cannot accept the selected duration automatically via cross-origin
        iframe prefill. Value is stored in sessionStorage as smallRepairVisitDurationHours
        for future handoff when a supported integration exists.
      -->
      <p class="mt-3 text-xs text-gray-400">
        Selected duration is saved in this browser session for your reference. Automatic transfer into
        the Jobber form is not available yet.
      </p>
    </div>
  </div>
</section>

<script>
  import { analyticsEvents, trackEvent } from '../../../utils/analytics';

  const STORAGE_KEY = 'smallRepairVisitDurationHours';

  function initPricingSelector() {
    const root = document.querySelector('[data-pricing-selector]');
    if (!root) return;

    const durationEl = root.querySelector('[data-summary-duration]');
    const priceEl = root.querySelector('[data-summary-price]');
    const radios = root.querySelectorAll<HTMLInputElement>('input[name="visit-duration"]');

    function applySelection(radio: HTMLInputElement) {
      const label = radio.getAttribute('data-duration-label') || radio.value;
      const price = radio.getAttribute('data-duration-price') || '';
      if (durationEl) durationEl.textContent = label;
      if (priceEl) priceEl.textContent = price;
      try {
        sessionStorage.setItem(STORAGE_KEY, radio.value);
      } catch {
        /* ignore */
      }
      trackEvent(analyticsEvents.durationSelected, {
        duration_hours: radio.value,
      });
    }

    radios.forEach((radio) => {
      radio.addEventListener('change', () => {
        if (radio.checked) applySelection(radio);
      });
    });

    const checked = root.querySelector<HTMLInputElement>('input[name="visit-duration"]:checked');
    if (checked) {
      try {
        sessionStorage.setItem(STORAGE_KEY, checked.value);
      } catch {
        /* ignore */
      }
    }

    const requestCta = root.querySelector('[data-request-cta]');
    requestCta?.addEventListener('click', () => {
      trackEvent(analyticsEvents.smallRepairRequestStarted, {
        duration_hours: checked?.value || '',
      });
    });
  }

  initPricingSelector();
</script>
