---
import { eligibleTasks } from '../../../data/smallRepairVisitContent';
---

<section id="eligible-tasks" class="py-16 md:py-20 bg-white" aria-labelledby="eligible-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-10">
      <p class="text-brand-red font-bold text-xs tracking-widest uppercase mb-2">What fits</p>
      <h2 id="eligible-heading" class="text-3xl font-bold text-brand-black mb-3">
        Examples of Appropriate Tasks
      </h2>
      <p class="text-gray-600 leading-relaxed">
        These are common uses for a Handyman To-Do List Visit. Eligibility depends on safety, complexity, and
        the details you provide — not every task is always appropriate.
      </p>
    </div>
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        eligibleTasks.map((task) => (
          <li class="flex items-start gap-3 rounded-lg border border-brand-line bg-brand-lightbg p-4 text-sm text-gray-700">
            <svg
              class="w-5 h-5 text-brand-red mt-0.5 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>{task}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
