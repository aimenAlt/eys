---
interface Props {
  steps?: string[];
}

const { steps } = Astro.props;
---

{
  steps && steps.length > 0 && (
    <section class="py-16 bg-brand-lightbg" aria-labelledby="process">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="process" class="text-3xl font-bold text-brand-black mb-8">
          Our Process
        </h2>
        <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {steps.map((step, index) => (
            <li class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm relative">
              <span class="text-5xl font-extrabold text-gray-100 absolute top-4 right-4">
                {String(index + 1).padStart(2, '0')}
              </span>
              <p class="relative z-10 text-sm text-gray-600 mt-4">{step}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )
}
