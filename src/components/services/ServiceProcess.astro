---
import BalancedGrid from '../ui/BalancedGrid.astro';
import { contentMaxClass, contentPaddingClass } from '../../data/layout';

interface Props {
  steps?: string[];
  embedded?: boolean;
  heading?: string;
}

const { steps, embedded = false, heading = 'Our Process' } = Astro.props;

const stepItems = (steps ?? []).map((body, index) => ({
  step: index + 1,
  body,
}));
---

{
  stepItems.length > 0 &&
    (embedded ? (
      <section aria-labelledby="process">
        <h2 id="process" class="text-2xl md:text-3xl font-bold text-brand-black mb-6">
          {heading}
        </h2>
        <BalancedGrid variant="step" items={stepItems} cols={4} gapClass="gap-4" />
      </section>
    ) : (
      <section class="py-16 md:py-20 bg-brand-lightbg" aria-labelledby="process">
        <div class:list={['mx-auto', contentMaxClass, contentPaddingClass]}>
          <p class="text-xs font-bold uppercase tracking-widest text-brand-red mb-2">How It Works</p>
          <h2 id="process" class="text-3xl md:text-4xl font-bold text-brand-black mb-8">
            {heading}
          </h2>
          <BalancedGrid variant="step" items={stepItems} cols={4} gapClass="gap-6" />
        </div>
      </section>
    ))
}
