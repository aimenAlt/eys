---
import BalancedGrid from '../ui/BalancedGrid.astro';
import { contentMaxClass, contentPaddingClass } from '../../data/layout';

interface Props {
  items?: string[];
  embedded?: boolean;
  heading?: string;
  locationName?: string;
}

const {
  items,
  embedded = false,
  heading = 'What We Do',
  locationName,
} = Astro.props;

const title = locationName ? `What we handle in ${locationName}` : heading;
const checklistItems = (items ?? []).map((text) => ({ text }));
---

{
  checklistItems.length > 0 &&
    (embedded ? (
      <section aria-labelledby="included">
        <h2 id="included" class="text-2xl md:text-3xl font-bold text-brand-black mb-6">
          {title}
        </h2>
        <BalancedGrid variant="checklist" items={checklistItems} cols={2} gapClass="gap-4" />
      </section>
    ) : (
      <section class="py-16 md:py-20 bg-brand-lightbg" aria-labelledby="included">
        <div class:list={['mx-auto', contentMaxClass, contentPaddingClass]}>
          <p class="text-xs font-bold uppercase tracking-widest text-brand-red mb-2">What We Do</p>
          <h2 id="included" class="text-3xl md:text-4xl font-bold text-brand-black mb-8">
            {title}
          </h2>
          <BalancedGrid variant="checklist" items={checklistItems} cols={2} gapClass="gap-4" />
        </div>
      </section>
    ))
}
