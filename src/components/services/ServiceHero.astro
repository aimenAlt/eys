---
import { jobberOnlineBookingUrl, site } from '../../data/business';
import { resolveServiceHero } from '../../data/images';
import { contentMaxClass, contentPaddingClass } from '../../data/layout';

interface ServiceData {
  heroTitle?: string;
  title: string;
  summary?: string;
  primaryCTA?: string;
  secondaryCTA?: string;
  bookingType?: string;
  slug: string;
  heroImage?: string;
  heroImageAlt?: string;
}

interface Props {
  service: ServiceData;
}

const { service } = Astro.props;
const heading = service.heroTitle ?? service.title;
const bookingUrl = jobberOnlineBookingUrl();
const imageSrc = resolveServiceHero(service.slug, service.heroImage);
const imageAlt = service.heroImageAlt ?? `${service.title} in Katy and West Houston`;

type CtaConfig = { href: string; label: string; external?: boolean };

function primaryCta(): CtaConfig {
  switch (service.bookingType) {
    case 'direct-book':
      return {
        href: bookingUrl ?? '/book/',
        label: service.primaryCTA ?? 'Book Online',
        external: Boolean(bookingUrl),
      };
    case 'assessment':
      return {
        href: '/contact/',
        label: service.primaryCTA ?? 'Schedule Assessment',
      };
    case 'call-only':
      return {
        href: `tel:${site.phoneTel}`,
        label: service.primaryCTA ?? `Call ${site.phone}`,
      };
    default:
      return {
        href: '/contact/',
        label: service.primaryCTA ?? 'Request a Quote',
      };
  }
}

const primary = primaryCta();
---

<section class="bg-white border-b border-gray-200" aria-labelledby="service-hero">
  <div class:list={['mx-auto', contentMaxClass, contentPaddingClass, 'py-10 md:py-12']}>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div>
        <h1 id="service-hero" class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-brand-black mb-4 leading-tight">
          {heading}
        </h1>
        {
          service.summary && (
            <p class="text-lg text-gray-600 leading-relaxed mb-6">{service.summary}</p>
          )
        }
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={primary.href}
            target={primary.external ? '_blank' : undefined}
            rel={primary.external ? 'noopener noreferrer' : undefined}
            class="gradient-btn text-white px-8 py-3 rounded-md font-bold text-center transition-all shadow-lg hover:shadow-xl"
          >
            {primary.label}
          </a>
          <a
            href={`tel:${site.phoneTel}`}
            class="inline-flex justify-center items-center border-2 border-brand-black text-brand-black px-8 py-3 rounded-md font-bold hover:bg-brand-black hover:text-white transition-all"
          >
            {service.secondaryCTA ?? `Call ${site.phone}`}
          </a>
        </div>
      </div>
      <div class="relative rounded-2xl overflow-hidden shadow-card ring-1 ring-brand-line aspect-[4/3] bg-brand-lightbg">
        <img
          src={imageSrc}
          alt={imageAlt}
          class="w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="800"
          height="600"
        />
      </div>
    </div>
  </div>
</section>
