---
import { contentMaxClass, contentPaddingClass } from '../../data/layout';

interface CommunityLink {
  title: string;
  href: string;
}

interface Props {
  communities: CommunityLink[];
}

const { communities } = Astro.props;
---

{
  communities.length > 0 && (
    <section class="py-12 bg-brand-lightbg" aria-labelledby="service-areas-served">
      <div class:list={['mx-auto', contentMaxClass, contentPaddingClass]}>
        <h2 id="service-areas-served" class="text-2xl font-bold text-brand-black mb-4">
          Communities we serve
        </h2>
        <p class="text-gray-600 mb-6 text-sm">
          This service is available throughout Katy and West Houston, including these master-planned communities:
        </p>
        <ul class="flex flex-wrap gap-2">
          {communities.map((c) => (
            <li>
              <a href={c.href} class="inline-block px-3 py-1.5 bg-white border border-gray-200 rounded-full text-sm font-medium text-brand-black hover:border-brand-red hover:text-brand-red transition-colors">
                {c.title}
              </a>
            </li>
          ))}
        </ul>
        <a href="/service-areas/" class="inline-block mt-4 text-sm font-bold text-brand-red hover:underline">View all service areas &rarr;</a>
      </div>
    </section>
  )
}
