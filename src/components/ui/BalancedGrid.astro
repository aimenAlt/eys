---
import {
  chunkBalanced,
  gridBreakpointForCols,
  uniformGridContainerClass,
  uniformGridStyle,
  uniformRowClass,
  uniformTileClass,
} from '../../utils/balancedGrid';
import { imageOrPlaceholder } from '../../data/images';

export type BalancedCardItem = {
  title: string;
  description?: string;
  href: string;
  footerText?: string;
  headingLevel?: 2 | 3;
  eyebrow?: string;
  eyebrowDatetime?: string;
  image?: string;
  imageAlt?: string;
};

export type BalancedLinkItem = {
  title: string;
  href: string;
};

export type BalancedValueItem = {
  title: string;
  body: string;
};

export type BalancedFeatureCardItem = {
  title: string;
  description: string;
  href: string;
  footerText: string;
};

export type BalancedProjectItem = {
  title: string;
  body: string;
  accentBar?: boolean;
  tone?: 'light' | 'white';
};

export type BalancedReviewItem = {
  author: string;
  rating: number;
  text: string;
  source: string;
  date: Date;
  location?: string;
};

export type BalancedChecklistItem = {
  text: string;
};

export type BalancedStepItem = {
  step: number;
  body: string;
};

export type BalancedGalleryItem = {
  src: string;
  alt: string;
  caption?: string;
  type?: string;
};

type VariantProps =
  | { variant: 'card'; items: BalancedCardItem[] }
  | { variant: 'link'; items: BalancedLinkItem[] }
  | { variant: 'value'; items: BalancedValueItem[] }
  | { variant: 'feature-card'; items: BalancedFeatureCardItem[] }
  | { variant: 'project'; items: BalancedProjectItem[] }
  | { variant: 'review'; items: BalancedReviewItem[] }
  | { variant: 'checklist'; items: BalancedChecklistItem[] }
  | { variant: 'step'; items: BalancedStepItem[] }
  | { variant: 'gallery'; items: BalancedGalleryItem[] };

function renderStars(rating: number): string {
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}

type GridItem =
  | BalancedCardItem
  | BalancedLinkItem
  | BalancedValueItem
  | BalancedFeatureCardItem
  | BalancedProjectItem
  | BalancedReviewItem
  | BalancedChecklistItem
  | BalancedStepItem
  | BalancedGalleryItem;

type Props = {
  variant: VariantProps['variant'];
  items: GridItem[];
  cols?: number;
  gapClass?: string;
  class?: string;
  listClass?: string;
  align?: 'left' | 'center';
};

const { variant, items, cols = 3, gapClass = 'gap-4', class: className, listClass, align } = Astro.props;
const rowChunks = chunkBalanced(items, cols);
const breakpoint = gridBreakpointForCols(cols);
const tileClass = uniformTileClass(breakpoint);
const rowClass = uniformRowClass(gapClass);
const gridStyle = uniformGridStyle(cols, gapClass);
const textAlign = align ?? 'left';
const linkAlignClass = textAlign === 'center' ? 'text-center' : 'text-left';
---

<div class:list={[uniformGridContainerClass(), className]} style={gridStyle}>
  {
    rowChunks.map((row) => (
      <ul class:list={[rowClass, listClass]} role="list">
        {
          row.map((item) => (
            <li class={tileClass}>
              {variant === 'link' && (
                <a
                  href={(item as BalancedLinkItem).href}
                  class:list={[
                    'group relative flex w-full h-full min-h-[3.25rem] min-w-0 items-center justify-between gap-3 overflow-hidden rounded-lg border border-brand-line bg-white py-3.5 pl-4 pr-3.5 font-semibold text-brand-black shadow-sm transition-all duration-200 hover:border-brand-red/50 hover:bg-brand-redsoft hover:shadow-card',
                    linkAlignClass,
                  ]}
                >
                  <span
                    class="absolute inset-y-0 left-0 w-1 bg-brand-red opacity-0 transition-opacity group-hover:opacity-100"
                    aria-hidden="true"
                  />
                  <span class="min-w-0 flex-1 text-sm leading-snug">{(item as BalancedLinkItem).title}</span>
                  <span
                    class="shrink-0 text-brand-red opacity-60 transition-all group-hover:translate-x-0.5 group-hover:opacity-100"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </a>
              )}
              {variant === 'card' && (() => {
                const card = item as BalancedCardItem;
                const HeadingTag = card.headingLevel === 3 ? 'h3' : 'h2';
                return (
                  <a
                    href={card.href}
                    class="group relative block h-full overflow-hidden rounded-xl border border-brand-line bg-white shadow-card transition-all duration-200 hover:-translate-y-0.5 hover:border-brand-red/40 hover:shadow-cardhover text-left"
                  >
                    <span
                      class="absolute inset-y-0 left-0 w-1.5 bg-brand-red"
                      aria-hidden="true"
                    />
                    {card.image && (
                      <img
                        src={imageOrPlaceholder(card.image)}
                        alt={card.imageAlt ?? card.title}
                        class="w-full aspect-[4/3] object-cover"
                        loading="lazy"
                        width="400"
                        height="300"
                      />
                    )}
                    <div class="p-6 pl-7 flex flex-col h-full min-h-[11rem]">
                    {card.eyebrow && (
                      <time
                        datetime={card.eyebrowDatetime}
                        class="text-xs text-brand-red font-bold uppercase tracking-wider"
                      >
                        {card.eyebrow}
                      </time>
                    )}
                    <HeadingTag class:list={['text-xl font-bold text-brand-black mb-2', card.eyebrow && 'mt-2']}>{card.title}</HeadingTag>
                    {card.description && (
                      <p class="text-sm text-gray-600 leading-relaxed flex-1">{card.description}</p>
                    )}
                    {card.footerText ? (
                      <span class="mt-5 inline-flex w-fit items-center gap-1.5 rounded-md bg-brand-red px-3 py-1.5 text-sm font-bold text-white transition-colors group-hover:bg-brand-redhover">
                        {card.footerText.replace(/\s*→\s*$/, '')}
                        <span aria-hidden="true">→</span>
                      </span>
                    ) : (
                      <span class="mt-5 inline-flex w-fit items-center gap-1 text-sm font-bold text-brand-red opacity-80 group-hover:opacity-100">
                        Learn more <span aria-hidden="true">→</span>
                      </span>
                    )}
                    </div>
                  </a>
                );
              })()}
              {variant === 'value' && (
                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm h-full text-left">
                  <h3 class="font-bold text-brand-black mb-3">{(item as BalancedValueItem).title}</h3>
                  <p class="text-sm text-gray-600 leading-relaxed">{(item as BalancedValueItem).body}</p>
                </div>
              )}
              {variant === 'feature-card' && (
                <a
                  href={(item as BalancedFeatureCardItem).href}
                  class="block h-full bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:border-brand-red/30 hover:shadow-md transition-all group text-left"
                >
                  <div class="w-1 h-8 bg-brand-red rounded-full mb-3 group-hover:h-10 transition-all" aria-hidden="true" />
                  <h3 class="font-bold text-brand-black mb-2 text-lg">{(item as BalancedFeatureCardItem).title}</h3>
                  <p class="text-sm text-gray-600 leading-relaxed mb-4">{(item as BalancedFeatureCardItem).description}</p>
                  <span class="text-sm font-bold text-brand-red">{(item as BalancedFeatureCardItem).footerText}</span>
                </a>
              )}
              {variant === 'project' && (() => {
                const project = item as BalancedProjectItem;
                const panelClass =
                  project.tone === 'light'
                    ? 'bg-brand-lightbg border-gray-100'
                    : 'bg-white border-gray-200 shadow-sm hover:border-brand-red/30 hover:shadow-md transition-all';
                return (
                  <div class:list={['h-full rounded-xl border p-5', panelClass]}>
                    {project.accentBar && (
                      <div class="w-1 h-8 bg-brand-red rounded-full mb-3" aria-hidden="true" />
                    )}
                    <h3 class="font-bold text-brand-black mb-2">{project.title}</h3>
                    <p class="text-sm text-gray-600 leading-relaxed">{project.body}</p>
                  </div>
                );
              })()}
              {variant === 'review' && (() => {
                const review = item as BalancedReviewItem;
                return (
                  <div class="h-full p-6 bg-brand-lightbg rounded-xl border border-gray-200">
                    <div class="flex items-center justify-between mb-3">
                      <p class="font-bold text-brand-black">{review.author}</p>
                      <span class="text-brand-red text-sm" aria-label={`${review.rating} out of 5 stars`}>
                        {renderStars(review.rating)}
                      </span>
                    </div>
                    <p class="text-gray-600 text-sm leading-relaxed mb-4">{review.text}</p>
                    <div class="text-xs text-gray-500 flex flex-wrap gap-x-3 gap-y-1">
                      <span>{review.source}</span>
                      <time datetime={review.date.toISOString()}>
                        {review.date.toLocaleDateString('en-US', {
                          year: 'numeric',
                          month: 'short',
                          day: 'numeric',
                        })}
                      </time>
                      {review.location && <span>{review.location}</span>}
                    </div>
                  </div>
                );
              })()}
              {variant === 'checklist' && (
                <div class="h-full flex items-start bg-white p-4 rounded-lg border border-gray-100 shadow-sm">
                  <svg
                    class="w-5 h-5 text-brand-red mr-3 mt-0.5 flex-shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-gray-700 text-sm">{(item as BalancedChecklistItem).text}</span>
                </div>
              )}
              {variant === 'step' && (() => {
                const step = item as BalancedStepItem;
                return (
                  <div class="h-full bg-white p-6 rounded-xl border border-brand-line shadow-card hover:shadow-cardhover transition-shadow">
                    <div class="flex items-center gap-3 mb-4">
                      <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-brand-red text-white font-extrabold text-lg" aria-hidden="true">
                        {String(step.step).padStart(2, '0')}
                      </span>
                      <span class="hidden md:block h-px flex-grow bg-brand-line" aria-hidden="true" />
                    </div>
                    <p class="text-sm text-gray-600 leading-relaxed">{step.body}</p>
                  </div>
                );
              })()}
              {variant === 'gallery' && (() => {
                const image = item as BalancedGalleryItem;
                return (
                  <figure class="h-full overflow-hidden rounded-lg bg-gray-100 shadow-sm">
                    <img
                      src={imageOrPlaceholder(image.src)}
                      alt={image.alt}
                      loading="lazy"
                      class="w-full h-64 object-cover"
                    />
                    {(image.caption || image.type) && (
                      <figcaption class="p-4 text-sm text-gray-600 bg-white">
                        {image.type && (
                          <span class="text-xs font-bold uppercase text-brand-red mr-2">{image.type}</span>
                        )}
                        {image.caption}
                      </figcaption>
                    )}
                  </figure>
                );
              })()}
            </li>
          ))
        }
      </ul>
    ))
  }
</div>
