---
interface Props {
  message?: string;
}

const { message } = Astro.props;
const displayMessage =
  message ?? '[PLACEHOLDER: Related project photos will appear here when available.]';
---

<section class="py-16 bg-brand-lightbg" aria-labelledby="area-projects">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="area-projects" class="text-3xl font-bold text-brand-black mb-6">
      Local Project Proof
    </h2>
    <p class="text-gray-600 mb-6 max-w-3xl">{displayMessage}</p>
    <a
      href="/projects/"
      class="inline-block text-brand-red font-bold hover:underline"
    >
      View all projects &rarr;
    </a>
  </div>
</section>
