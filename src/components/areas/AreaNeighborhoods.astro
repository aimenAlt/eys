---
interface Props {
  neighborhoods?: string[];
  localIntro?: string;
}

const { neighborhoods, localIntro } = Astro.props;
---

{
  (localIntro || (neighborhoods && neighborhoods.length > 0)) && (
    <section class="py-16 bg-brand-lightbg" aria-labelledby="neighborhoods">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="neighborhoods" class="text-3xl font-bold text-brand-black mb-6">
          Neighborhoods We Serve
        </h2>
        {localIntro && <p class="text-gray-600 mb-8 max-w-3xl leading-relaxed">{localIntro}</p>}
        {
          neighborhoods && neighborhoods.length > 0 && (
            <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-y-3 gap-x-4">
              {neighborhoods.map((name) => (
                <li class="flex items-center text-sm font-medium text-brand-black">
                  <span class="w-2 h-2 bg-brand-red rounded-full mr-2 flex-shrink-0" />
                  {name}
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </section>
  )
}
