---
import BalancedGrid from '../ui/BalancedGrid.astro';

interface Project {
  name: string;
  description: string;
}

interface Props {
  communityName: string;
  servicesIntro?: string;
  commonProjects?: Project[];
}

const { communityName, servicesIntro, commonProjects } = Astro.props;

const projectItems =
  commonProjects?.map((project) => ({
    title: project.name,
    body: project.description,
    tone: 'light' as const,
  })) ?? [];
---

{
  commonProjects && commonProjects.length > 0 && (
    <section class="py-16 bg-white" aria-labelledby="community-projects">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="community-projects" class="text-3xl font-bold text-brand-black mb-4">
          Handyman Services for {communityName} Homes
        </h2>
        {servicesIntro && (
          <p class="text-gray-600 mb-10 max-w-3xl text-lg leading-relaxed">{servicesIntro}</p>
        )}
        <h3 class="text-xl font-bold text-brand-black mb-6">Common Projects We Help With</h3>
        <BalancedGrid variant="project" items={projectItems} cols={3} gapClass="gap-4" />
      </div>
    </section>
  )
}
