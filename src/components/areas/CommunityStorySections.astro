---
interface Props {
  communityName: string;
  whyChoose?: string;
  goodFit?: string;
  localLifestyle?: string;
  process?: string;
}

const { communityName, whyChoose, goodFit, localLifestyle, process } = Astro.props;

const sections = [
  {
    id: 'why-choose',
    title: `Why ${communityName} Homeowners Choose EYS`,
    body: whyChoose,
    bg: 'bg-brand-lightbg',
  },
  {
    id: 'good-fit',
    title: 'Good Fit Projects',
    body: goodFit,
    bg: 'bg-white',
  },
  {
    id: 'local-lifestyle',
    title: 'Local Lifestyle Angle',
    body: localLifestyle,
    bg: 'bg-brand-lightbg',
  },
  {
    id: 'process',
    title: 'How the Process Works',
    body: process,
    bg: 'bg-white',
  },
].filter((section) => section.body);
---

{
  sections.map((section) => (
    <section class={`py-16 ${section.bg}`} aria-labelledby={section.id}>
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id={section.id} class="text-2xl md:text-3xl font-bold text-brand-black mb-6">
          {section.title}
        </h2>
        <p class="text-gray-600 leading-relaxed text-lg">{section.body}</p>
      </div>
    </section>
  ))
}
