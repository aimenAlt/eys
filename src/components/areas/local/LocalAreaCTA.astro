---
import { site } from '../../../data/business';

interface Props {
  locationName: string;
}

const { locationName } = Astro.props;
---

<section class="bg-brand-black text-white border-t border-white/10" aria-labelledby="local-cta">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-16 text-center">
    <p class="text-brand-red text-xs font-bold uppercase tracking-widest mb-3">Next step</p>
    <h2 id="local-cta" class="text-2xl md:text-3xl font-bold mb-4">
      Ready to elevate your {locationName} home?
    </h2>
    <p class="text-gray-300 mb-8 text-sm md:text-base leading-relaxed">
      Send your project list or photos for a clear estimate. Premium, white-glove handyman work for {locationName} and nearby West Houston communities.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="/contact/"
        class="inline-flex justify-center items-center bg-brand-red text-white px-8 py-3.5 rounded-md font-bold hover:bg-brand-redhover transition-colors"
      >
        Request an Estimate
      </a>
      <a
        href={`tel:${site.phoneTel}`}
        class="inline-flex justify-center items-center border-2 border-white/30 text-white px-8 py-3.5 rounded-md font-bold hover:border-white transition-colors"
      >
        Call {site.phone}
      </a>
    </div>
  </div>
</section>
