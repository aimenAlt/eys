---
import { getCollection } from 'astro:content';
import BalancedGrid from '../../ui/BalancedGrid.astro';

interface Props {
  serviceSlugs?: string[];
  locationName: string;
}

const { serviceSlugs, locationName } = Astro.props;

const allServices = await getCollection('services', ({ data }) => data.published === true);
const titleBySlug = Object.fromEntries(allServices.map((entry) => [entry.data.slug, entry.data.title]));

function formatServiceName(slug: string): string {
  return titleBySlug[slug] ?? slug
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const linkItems =
  serviceSlugs?.map((slug) => ({
    title: formatServiceName(slug),
    href: `/services/${slug}/`,
  })) ?? [];
---

{
  linkItems.length > 0 && (
    <section aria-labelledby="local-services">
      <p class="text-xs font-bold uppercase tracking-widest text-brand-red mb-2">Services</p>
      <h2 id="local-services" class="text-2xl md:text-3xl font-bold text-brand-black mb-4">
        Handyman services in {locationName}
      </h2>
      <BalancedGrid variant="link" items={linkItems} cols={3} gapClass="gap-3" />
    </section>
  )
}
