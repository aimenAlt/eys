---
import BalancedGrid from '../../ui/BalancedGrid.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
  locationName: string;
  placeholder?: string;
}

const { projects, locationName, placeholder } = Astro.props;

function projectThumbnail(entry: CollectionEntry<'projects'>): string | undefined {
  const featured = entry.data.gallery?.find((img) => img.featured);
  return featured?.src ?? entry.data.gallery?.[0]?.src;
}

const projectCards = projects.map((entry) => {
  const thumb = projectThumbnail(entry);
  return {
    title: entry.data.title,
    description: entry.data.summary,
    href: `/projects/${entry.data.slug}/`,
    image: thumb?.replace('w=800', 'w=400'),
    imageAlt: entry.data.gallery?.[0]?.alt ?? entry.data.title,
  };
});
---

{
  projects.length > 0 ? (
    <section aria-labelledby="area-projects">
      <p class="text-xs font-bold uppercase tracking-widest text-brand-red mb-2">Recent work</p>
      <h2 id="area-projects" class="text-2xl md:text-3xl font-bold text-brand-black mb-6">
        Projects in {locationName}
      </h2>
      <BalancedGrid variant="card" items={projectCards} cols={3} gapClass="gap-6" />
    </section>
  ) : (
    placeholder && (
      <section aria-labelledby="area-projects">
        <p class="text-xs font-bold uppercase tracking-widest text-brand-red mb-2">Recent work</p>
        <h2 id="area-projects" class="text-2xl md:text-3xl font-bold text-brand-black mb-4">
          Projects in {locationName}
        </h2>
        <p class="text-gray-600">{placeholder}</p>
      </section>
    )
  )
}
