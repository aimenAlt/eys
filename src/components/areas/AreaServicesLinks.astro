---
import { getCollection } from 'astro:content';
import BalancedGrid from '../ui/BalancedGrid.astro';

interface Props {
  serviceSlugs?: string[];
  cityName: string;
}

const { serviceSlugs, cityName } = Astro.props;

const allServices = await getCollection('services', ({ data }) => data.published === true);
const titleBySlug = Object.fromEntries(allServices.map((entry) => [entry.data.slug, entry.data.title]));

function formatServiceName(slug: string): string {
  return titleBySlug[slug] ?? slug
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const linkItems =
  serviceSlugs?.map((slug) => ({
    title: formatServiceName(slug),
    href: `/services/${slug}/`,
  })) ?? [];
---

{
  linkItems.length > 0 && (
    <section class="py-16 bg-white" aria-labelledby="area-services">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="area-services" class="text-3xl font-bold text-brand-black mb-8">
          Services Available in {cityName}
        </h2>
        <BalancedGrid variant="link" items={linkItems} cols={3} gapClass="gap-4" />
      </div>
    </section>
  )
}
