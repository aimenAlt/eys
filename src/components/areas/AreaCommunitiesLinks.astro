---
import BalancedGrid from '../ui/BalancedGrid.astro';

interface CommunityLink {
  title: string;
  slug: string;
  summary?: string;
}

interface Props {
  communities: CommunityLink[];
  citySlug: string;
  cityName: string;
}

const { communities, citySlug, cityName } = Astro.props;

const communityCards = communities.map((community) => ({
  title: community.title,
  description: community.summary,
  href: `/service-areas/${citySlug}/${community.slug}/`,
  footerText: 'View community page →',
  headingLevel: 3 as const,
}));
---

{
  communities.length > 0 && (
    <section class="py-16 bg-brand-lightbg" aria-labelledby="communities">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="communities" class="text-3xl font-bold text-brand-black mb-4">
          Communities We Serve in {cityName}
        </h2>
        <p class="text-gray-600 mb-8 max-w-3xl">
          Select your master-planned community for localized handyman services, preferred community pricing, and area-specific project guidance.
        </p>
        <BalancedGrid variant="card" items={communityCards} cols={3} gapClass="gap-6" />
      </div>
    </section>
  )
}
