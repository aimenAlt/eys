---
import type { CollectionEntry } from 'astro:content';
import BalancedGrid from '../ui/BalancedGrid.astro';
import { googleReviews, googleReviewProfileUrl } from '../../data/business';
import { contentMaxClass, contentPaddingClass } from '../../data/layout';

interface Props {
  reviews: CollectionEntry<'reviews'>[];
}

const { reviews } = Astro.props;
const gbpUrl = googleReviewProfileUrl();

const featured = reviews.filter((r) => r.data.featured).slice(0, 3);
const display = featured.length > 0 ? featured : reviews.slice(0, 3);

const reviewItems = display.map((entry) => ({
  author: entry.data.author,
  rating: entry.data.rating,
  text: entry.data.text,
  source: entry.data.source,
  date: entry.data.date,
  location: entry.data.location,
}));
---

<section class="py-20 bg-white">
  <div class:list={['mx-auto', contentMaxClass, contentPaddingClass]}>
    <div class="text-center mb-12">
      <p class="text-brand-red font-bold text-sm tracking-widest uppercase mb-2">Testimonials</p>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-black mb-4">Customer Reviews</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        {googleReviews.rating.toFixed(1)} stars from {googleReviews.count}+ Google reviews. Here are a few featured testimonials from Katy and West Houston homeowners.
      </p>
      <p class="mt-3 text-sm">
        {
          gbpUrl ? (
            <>
              <a href={gbpUrl} target="_blank" rel="noopener noreferrer" class="text-brand-red font-bold hover:underline">Read all Google reviews</a>
              <span class="text-gray-400 mx-2">·</span>
            </>
          ) : null
        }
        <a href="/reviews/" class="text-brand-red font-bold hover:underline">View reviews on our site</a>
      </p>
    </div>

    {
      reviewItems.length > 0 ? (
        <BalancedGrid variant="review" items={reviewItems} cols={3} gapClass="gap-6" />
      ) : (
        <div class="text-center">
          <a href="/reviews/" class="inline-block text-brand-red font-bold hover:underline">
            View reviews page
          </a>
        </div>
      )
    }

    <div class="mt-10 text-center">
      <a
        href="/contact/"
        class="inline-block gradient-btn text-white px-8 py-3 rounded-md font-bold transition-all shadow-md"
      >
        Contact Us About Your Project
      </a>
    </div>
  </div>
</section>
