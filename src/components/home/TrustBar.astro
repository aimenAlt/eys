---
import { googleReviews, googleReviewProfileUrl } from '../../data/business';

interface Props {
  projectCount: number;
}

const { projectCount } = Astro.props;
const gbpUrl = googleReviewProfileUrl();
const ratingLabel = googleReviews.rating.toFixed(1);
const reviewLabel = `${googleReviews.count}+`;
---

<section class="bg-brand-red py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center divide-x-0 md:divide-x divide-white/20">
      <div class="p-4">
        <div class="text-3xl md:text-4xl font-extrabold text-white mb-1">Veteran</div>
        <div class="text-sm text-white/90 font-medium uppercase tracking-wide">Owned & Operated</div>
      </div>
      <div class="p-4">
        <div class="text-3xl md:text-4xl font-extrabold text-white mb-1">Katy</div>
        <div class="text-sm text-white/90 font-medium uppercase tracking-wide">Based & Local</div>
      </div>
      <div class="p-4">
        <div class="text-3xl md:text-4xl font-extrabold text-white mb-1">{projectCount > 0 ? projectCount : '12+'}</div>
        <div class="text-sm text-white/90 font-medium uppercase tracking-wide">Communities Served</div>
      </div>
      <div class="p-4">
        {
          gbpUrl ? (
            <a href={gbpUrl} target="_blank" rel="noopener noreferrer" class="block hover:opacity-90 transition-opacity">
              <div class="flex items-center justify-center gap-2 mb-1">
                <svg class="w-6 h-6" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="#ffffff" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
                  <path fill="#ffffff" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                  <path fill="#ffffff" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                  <path fill="#ffffff" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                </svg>
                <span class="text-3xl md:text-4xl font-extrabold text-white">{ratingLabel}</span>
              </div>
              <div class="text-sm text-white/90 font-medium uppercase tracking-wide">{reviewLabel} Google Reviews</div>
            </a>
          ) : (
            <>
              <div class="flex items-center justify-center gap-2 mb-1">
                <svg class="w-6 h-6" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="#ffffff" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
                  <path fill="#ffffff" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                  <path fill="#ffffff" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                  <path fill="#ffffff" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                </svg>
                <span class="text-3xl md:text-4xl font-extrabold text-white">{ratingLabel}</span>
              </div>
              <div class="text-sm text-white/90 font-medium uppercase tracking-wide">{reviewLabel} Google Reviews</div>
            </>
          )
        }
      </div>
    </div>
  </div>
</section>
