---
import type { CollectionEntry } from 'astro:content';
import { imageOrPlaceholder } from '../../data/images';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section id="gallery" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold text-brand-black mb-4">Recent Projects</h2>
        <p class="text-gray-600">See examples of repair, installation, and upgrade work completed for local homeowners.</p>
      </div>
      <a href="/projects/" class="hidden md:inline-block mt-4 md:mt-0 text-brand-red font-bold hover:underline">View Gallery &rarr;</a>
    </div>

    {
      projects.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {projects.slice(0, 6).map((project) => {
            const img = project.data.gallery?.[0];
            return (
              <a href={`/projects/${project.data.slug}/`} class="aspect-square overflow-hidden rounded-lg bg-gray-100 block group">
                {img ? (
                  <img src={imageOrPlaceholder(img.src)} loading="lazy" class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-300" alt={img.alt} width="400" height="400" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-gray-400 text-sm p-4 text-center">{project.data.title}</div>
                )}
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12 bg-brand-lightbg rounded-xl border border-gray-100">
          <p class="text-gray-600 mb-4">Project photos are being added. Check back soon or contact us about recent work in your area.</p>
          <a href="/contact/" class="inline-block py-3 px-6 bg-brand-red text-white font-bold rounded hover:bg-brand-redhover transition-colors">Request References</a>
        </div>
      )
    }

    <div class="mt-8 text-center md:hidden">
      <a href="/projects/" class="inline-block py-3 px-6 border border-brand-red text-brand-red font-bold rounded hover:bg-brand-red hover:text-white transition-colors">View Gallery</a>
    </div>
  </div>
</section>
