---
import type { FaqItem } from '../../data/schema';

interface Props {
  faqs: FaqItem[];
}

const { faqs } = Astro.props;
---

<section class="py-20 bg-brand-lightbg" aria-labelledby="home-faq">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="home-faq" class="text-3xl font-bold text-brand-black">Frequently Asked Questions</h2>
    </div>

    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200 group">
            <summary class="flex justify-between items-center font-bold font-lg p-6 focus:outline-none text-brand-black cursor-pointer">
              {faq.question}
              <span class="transition group-open:rotate-180 text-brand-red flex-shrink-0 ml-4">
                <svg fill="none" height="24" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-gray-600 text-sm">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
