---
interface CityLink {
  title: string;
  slug: string;
}

interface CommunityLink {
  title: string;
  citySlug: string;
  slug: string;
}

interface Props {
  cities: CityLink[];
  communities: CommunityLink[];
}

const { cities, communities } = Astro.props;
---

<section id="area" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-start">
      <div class="mb-10 lg:mb-0">
        <h2 class="text-3xl font-bold text-brand-black mb-4">Proudly serving Katy and West Houston</h2>
        <p class="text-gray-600 mb-6">
          Elevate Your Space Handyman provides premium handyman services throughout Katy, Cypress, Fulshear, Richmond, and West Houston — including the master-planned communities below.
        </p>
        <div class="bg-brand-lightbg p-6 rounded-lg border border-gray-100 mb-6">
          <h3 class="font-bold text-brand-black mb-3 text-sm uppercase tracking-wide">Cities we serve</h3>
          <ul class="grid grid-cols-2 gap-y-2 gap-x-4 text-sm font-medium">
            {cities.map((city) => (
              <li>
                <a href={`/service-areas/${city.slug}/`} class="text-brand-black hover:text-brand-red transition-colors flex items-center">
                  <span class="w-2 h-2 bg-brand-red rounded-full mr-2 flex-shrink-0" />
                  {city.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
        {
          communities.length > 0 && (
            <div class="bg-brand-lightbg p-6 rounded-lg border border-gray-100">
              <h3 class="font-bold text-brand-black mb-3 text-sm uppercase tracking-wide">Featured communities</h3>
              <ul class="grid grid-cols-2 gap-y-2 gap-x-4 text-sm">
                {communities.map((c) => (
                  <li>
                    <a href={`/service-areas/${c.citySlug}/${c.slug}/`} class="text-gray-700 hover:text-brand-red transition-colors">
                      {c.title}
                    </a>
                  </li>
                ))}
              </ul>
              <a href="/service-areas/" class="inline-block mt-4 text-sm font-bold text-brand-red hover:underline">View all service areas &rarr;</a>
            </div>
          )
        }
      </div>
      <div class="w-full h-80 lg:min-h-[420px] bg-gray-200 rounded-xl overflow-hidden shadow-inner relative">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d110825.2662057922!2d-95.89518040445695!3d29.771960205256434!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8640d00f8da75c01%3A0xcad46f5de0fde2c9!2sKaty%2C%20TX!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
          width="100%"
          height="100%"
          style="border:0; position:absolute; top:0; left:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Katy TX service area map"
        ></iframe>
        <p class="sr-only">
          Interactive map of our Katy and West Houston service area.
          <a href="https://www.google.com/maps/search/?api=1&query=1308+Ventura+Crk+Dr,+Katy,+TX+77493">Open 1308 Ventura Crk Dr, Katy, TX in Google Maps</a>
        </p>
      </div>
    </div>
  </div>
</section>
