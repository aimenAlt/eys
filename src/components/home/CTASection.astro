---
import { homeImages, hasImage } from '../../data/images';
---
    <section class="relative py-20 bg-brand-black text-center">
        {hasImage(homeImages.ctaBg) && (
        <div class="absolute inset-0 overflow-hidden">
            <img src={homeImages.ctaBg} loading="lazy" class="w-full h-full object-cover opacity-10" alt="" width="1920" height="1080">
        </div>
        )}
        <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Get Started Today</h2>
            <p class="text-gray-300 mb-8 leading-relaxed text-sm md:text-base">
                Ready to cross items off your home to-do list? Send us your project details or punch list for a clear estimate. We serve Katy and West Houston with premium, white-glove handyman service.
            </p>
            <a href="/contact/" class="inline-block bg-brand-red text-white px-8 py-4 rounded-md font-bold hover:bg-brand-redhover transition-colors shadow-lg">
                Request an Estimate
            </a>
        </div>
    </section>
