---
import { serviceCategories } from '../../data/serviceCategories';
import { hasImage } from '../../data/images';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="services" class="py-20 md:py-24 bg-brand-lightbg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="What We Offer"
      title="Our Services"
      intro="Reliable help is just a call away. Our team is ready to tackle your to-do list with care and professionalism, making life easier for you."
      align="center"
    />

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
      {
        serviceCategories.map((category) => (
          <div class="relative rounded-2xl overflow-hidden group shadow-card hover:shadow-cardhover transition-shadow duration-300 flex flex-col h-full bg-brand-black">
            {hasImage(category.heroImage) && (
              <img
                src={category.heroImage}
                loading="lazy"
                class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-30 transition-opacity duration-500"
                alt={category.heroImageAlt}
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-br from-brand-charcoal via-brand-black to-black" />
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(176,0,0,0.25),transparent_60%)]" />

            <div class="relative p-8 flex flex-col h-full z-10">
              <h3 class="text-2xl font-bold text-white mb-3">{category.title}</h3>
              <p class="text-gray-300 text-sm mb-6 leading-relaxed">{category.summary}</p>

              <ul class="flex-grow space-y-3 mb-8">
                {category.items.map((item) => (
                  <li class="border-l-2 border-brand-red pl-4">
                    {item.serviceSlug ? (
                      <a
                        href={`/services/${item.serviceSlug}/`}
                        class="font-semibold text-white text-sm hover:text-brand-red transition-colors"
                      >
                        {item.title}
                      </a>
                    ) : (
                      <p class="font-semibold text-white text-sm">{item.title}</p>
                    )}
                  </li>
                ))}
              </ul>
              <a
                href={`/services/${category.slug}/`}
                class="inline-flex items-center justify-center w-full py-3 px-4 bg-brand-red text-white text-center font-bold rounded-lg hover:bg-brand-redhover transition-colors mt-auto"
              >
                {category.ctaLabel}
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
