---
import { serviceCategories } from '../../data/serviceCategories';
---

<section id="services" class="py-20 bg-brand-lightbg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h4 class="text-brand-red font-bold text-sm tracking-widest uppercase mb-2">What We Offer</h4>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-black mb-6">Our Services</h2>
      <p class="text-gray-600 text-lg">
        Reliable help is just a call away. Our team is ready to tackle your to do list with care and professionalism, making life easier for you.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {
        serviceCategories.map((category) => (
          <div class="relative rounded-2xl overflow-hidden group shadow-xl flex flex-col h-full bg-black">
            <img
              src={`${category.heroImage.replace('w=1200', 'w=600')}`}
              loading="lazy"
              class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-30 transition-opacity duration-500"
              alt={category.heroImageAlt}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 to-transparent" />

            <div class="relative p-8 flex flex-col h-full z-10">
              <h3 class="text-2xl font-bold text-white mb-3">{category.title}</h3>
              <p class="text-gray-300 text-sm mb-6">{category.summary}</p>

              <div class="flex-grow overflow-y-auto custom-scrollbar pr-2 mb-6 space-y-4">
                {
                  category.items.map((item) => (
                    <div class="border-l-2 border-brand-red pl-4">
                      <h4 class="font-bold text-white text-sm">{item.title}</h4>
                      <p class="text-xs text-gray-400 mt-1">{item.description}</p>
                    </div>
                  ))
                }
              </div>
              <a
                href={`/services/${category.slug}/`}
                class="inline-block w-full py-3 px-4 bg-brand-red text-white text-center font-bold rounded hover:bg-brand-redhover transition-colors mt-auto"
              >
                {category.ctaLabel}
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
