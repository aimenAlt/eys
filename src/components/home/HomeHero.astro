---
import JobberEmbedWrapper from '../booking/JobberEmbedWrapper.astro';
import { jobberRequestFormUrl, site } from '../../data/business';
import { homeImageAlts, homeImages, imageOrPlaceholder } from '../../data/images';

const requestFormUrl = jobberRequestFormUrl();
const heroSrc = imageOrPlaceholder(homeImages.hero);
---

<section class="relative overflow-hidden bg-brand-black min-h-[min(92vh,880px)]">
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src={heroSrc}
      alt={homeImageAlts.hero}
      width="1600"
      height="1200"
      fetchpriority="high"
      decoding="async"
      class="h-full w-full object-cover object-[center_40%]"
    />
    <!-- Keep most of the photo visible; only shade the copy column -->
    <div
      class="absolute inset-0 bg-gradient-to-r from-brand-black/75 via-brand-black/35 to-transparent md:via-brand-black/25"
    >
    </div>
    <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-brand-black/45 to-transparent">
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-16 lg:pt-24 lg:pb-28">
    <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-center">
      <div class="lg:col-span-7">
        <span
          class="inline-block py-1 px-3 rounded-md bg-black/35 text-white text-xs font-bold tracking-wider mb-4 border border-white/30 uppercase backdrop-blur-[2px]"
        >
          Veteran-Owned · Katy &amp; West Houston
        </span>
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6 [text-shadow:0_2px_24px_rgba(0,0,0,0.55)]"
        >
          Veteran-Owned Handyman for Katy &amp; West Houston
        </h1>
        <p
          class="text-lg text-white/95 mb-8 leading-relaxed max-w-2xl [text-shadow:0_1px_12px_rgba(0,0,0,0.5)]"
        >
          Looking for a dependable handyman near you? Elevate Your Space handles TV mounting, ceiling
          fans, trim work, punch-list repairs, and move-in upgrades across Katy and West Houston —
          with clear free estimates and clean execution.
        </p>
        <div class="mb-10">
          <a
            href={`tel:${site.phoneTel}`}
            class="inline-flex w-full sm:w-auto justify-center items-center bg-white text-brand-black border-2 border-white px-8 py-4 rounded-md font-bold text-center hover:bg-brand-red hover:border-brand-red hover:text-white transition-all"
          >
            Call {site.phone}
          </a>
        </div>
        <div
          class="flex flex-wrap items-center gap-4 text-sm font-medium text-white/90 [text-shadow:0_1px_8px_rgba(0,0,0,0.45)]"
        >
          <span class="flex items-center gap-1">
            <svg class="w-5 h-5 text-brand-redondark" fill="currentColor" viewBox="0 0 20 20"
              ><path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"></path></svg
            >
            Veteran-Owned
          </span>
          <span class="hidden sm:inline text-white/40">•</span>
          <span class="flex items-center gap-1">
            <svg class="w-5 h-5 text-brand-redondark" fill="currentColor" viewBox="0 0 20 20"
              ><path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"></path></svg
            >
            White-Glove Cleanup
          </span>
          <span class="hidden sm:inline text-white/40">•</span>
          <a
            href="/service-areas/"
            class="flex items-center gap-1 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5 text-brand-redondark" fill="currentColor" viewBox="0 0 20 20"
              ><path
                fill-rule="evenodd"
                d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                clip-rule="evenodd"></path></svg
            >
            12+ Communities Served
          </a>
        </div>
      </div>
      <div id="estimate" class="lg:col-span-5 mt-12 lg:mt-0 scroll-mt-24">
        <JobberEmbedWrapper
          embedUrl={requestFormUrl}
          title="Get a clear estimate"
          minHeight="480px"
          class="shadow-2xl ring-1 ring-black/10"
        />
      </div>
    </div>
  </div>
</section>
