---
import {
  jobberHandymanToDoListFormUrl,
  jobberOnlineBookingUrl,
  jobberProjectEstimateFormUrl,
  site,
} from '../../data/business';

const bookingForms = [
  {
    title: 'Handyman To-Do List Visit',
    description:
      'Book a handyman to work through multiple small repairs, installations, and maintenance tasks in one visit.',
    href: jobberHandymanToDoListFormUrl(),
  },
  {
    title: 'Project Estimate Request',
    description:
      'Tell us about your project and upload photos. We will review and prepare an itemized estimate.',
    href: jobberProjectEstimateFormUrl(),
  },
  {
    title: 'Tell Us About Your TV Mounting Project',
    description:
      'Answer a few questions and upload photos so we can verify pricing and bring the right materials.',
    href: jobberOnlineBookingUrl(),
  },
].filter((form) => Boolean(form.href));
---

<section class="py-10 md:py-12 bg-white" aria-labelledby="booking-options">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h1 id="booking-options" class="text-4xl md:text-5xl font-extrabold text-brand-black mb-4">
        Book or Request Service
      </h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Choose a form to get started with {site.name} in Katy and West Houston.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        bookingForms.map((form) => (
          <a
            href={form.href}
            target="_blank"
            rel="noopener noreferrer"
            class="block p-6 bg-brand-lightbg rounded-xl border border-gray-200 hover:border-brand-red/30 hover:shadow-md transition-all text-center"
          >
            <h2 class="text-xl font-bold text-brand-black mb-2">{form.title}</h2>
            <p class="text-sm text-gray-600">{form.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
