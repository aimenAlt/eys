---
import { absoluteUrl, site } from '../../data/business';
import { defaultOgImage, defaultOgImageAlt } from '../../data/images';
import { withBase } from '../../utils/paths';

export interface SeoProps {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  /** Accessible description of the OG/Twitter share image. */
  ogImageAlt?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = site.defaultOgImage,
  ogImageAlt = defaultOgImageAlt,
  ogType = 'website',
  noindex = false,
} = Astro.props as SeoProps;

// Preview deploys (GitHub Pages base path, or PUBLIC_DEPLOY_ENV=preview) stay out of search indexes.
const isGithubPagesPreview = (import.meta.env.BASE_URL || '/') !== '/';
const isCloudflarePreview = import.meta.env.PUBLIC_DEPLOY_ENV === 'preview';
const robotsNoindex = noindex || isGithubPagesPreview || isCloudflarePreview;
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : absoluteUrl(ogImage);
const isDefaultOg =
  ogImage === defaultOgImage ||
  ogImage === site.defaultOgImage ||
  resolvedOgImage.endsWith('/images/og-default.jpg');
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={site.name} />
{robotsNoindex && <meta name="robots" content="noindex, nofollow" />}
{canonical && <link rel="canonical" href={canonical} />}
<link rel="icon" href={withBase('/favicon.ico')} sizes="any" />
<link rel="icon" type="image/png" sizes="512x512" href={withBase('/favicon-512.png')} />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
{canonical && <meta property="og:url" content={canonical} />}
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:alt" content={ogImageAlt} />
{isDefaultOg && <meta property="og:image:width" content="1200" />}
{isDefaultOg && <meta property="og:image:height" content="630" />}
<link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />
