---
import type { NavMenuGroup } from '../../data/navMenus';
import { withBase } from '../../utils/paths';

interface Props {
  menu: NavMenuGroup;
  mobileLinkClass?: string;
}

const { menu, mobileLinkClass = 'block px-3 py-2 rounded-md text-base font-medium hover:bg-brand-red' } = Astro.props;
---

<details class="group border-b border-gray-700/50">
  <summary class={`${mobileLinkClass} flex justify-between items-center cursor-pointer list-none`}>
    <span>{menu.label}</span>
    <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>
  <div class="pl-3 pb-2 space-y-1">
    <a href={withBase(menu.href)} class="block px-3 py-2 text-sm text-brand-red font-bold" data-close-mobile-menu>
      View all {menu.label}
    </a>
    {menu.children.map((item) => (
      <div>
        <a href={withBase(item.href)} class="block px-3 py-2 text-sm text-gray-200 hover:text-white" data-close-mobile-menu>
          {item.label}
        </a>
        {
          item.children && (
            <div class="pl-4 space-y-0.5">
              {item.children.map((child) => (
                <a href={withBase(child.href)} class="block px-3 py-1.5 text-xs text-gray-400 hover:text-white" data-close-mobile-menu>
                  {child.label}
                </a>
              ))}
            </div>
          )
        }
      </div>
    ))}
  </div>
</details>
