---
import NavLink from './NavLink.astro';
import { mainNav } from '../../data/navigation';

const desktopLinkClass =
  'text-sm font-medium hover:text-brand-red transition-colors';
const mobileLinkClass =
  'block px-3 py-2 rounded-md text-base font-medium hover:bg-brand-red';
---

    <header class="bg-brand-black text-white sticky top-0 z-50 shadow-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <!-- Logo -->
                <div class="flex-shrink-0 flex items-center">
                    <a href="/" class="text-2xl font-bold tracking-tight">
                        Elevate Your Space<span class="text-brand-red">.</span>
                    </a>
                </div>
                
                <!-- Desktop Nav -->
                <nav class="hidden md:flex space-x-8 items-center">
                    {mainNav.map((item) => (
                        <NavLink
                            href={item.href}
                            label={item.label}
                            class={desktopLinkClass}
                        />
                    ))}
                </nav>

                <!-- CTA Button -->
                <div class="hidden md:flex items-center bg-brand-red/10 px-4 py-2 rounded-md border border-brand-red/20">
                    <div class="flex flex-col items-end">
                        <span class="text-xs text-brand-red font-bold uppercase tracking-wider">Need Help?</span>
                        <a href="tel:7189861177" class="font-bold text-lg hover:text-brand-red transition-colors">(718) 986-1177</a>
                    </div>
                </div>

                <!-- Mobile menu button -->
                <div class="flex items-center md:hidden">
                    <button type="button" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" class="text-gray-300 hover:text-white focus:outline-none p-2" aria-label="Toggle menu">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Nav -->
        <div id="mobile-menu" class="hidden md:hidden bg-brand-charcoal border-t border-gray-800">
            <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                {mainNav.map((item) => (
                    <NavLink
                        href={item.href}
                        label={item.label}
                        class={mobileLinkClass}
                        closeMobileMenu
                    />
                ))}
                <a href="tel:7189861177" class="block px-3 py-3 mt-4 bg-brand-red text-white text-center rounded-md font-bold text-lg">Call: (718) 986-1177</a>
            </div>
        </div>
    </header>
