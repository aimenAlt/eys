---
import NavLink from './NavLink.astro';
import NavDropdown from './NavDropdown.astro';
import NavMobileAccordion from './NavMobileAccordion.astro';
import { mainNav } from '../../data/navigation';
import type { NavMenus } from '../../data/navMenus';
import Logo from './Logo.astro';
import { site } from '../../data/business';

interface Props {
  navMenus: NavMenus;
}

const { navMenus } = Astro.props;

const desktopLinkClass =
  'nav-underline text-sm font-medium hover:text-brand-red transition-colors';
const mobileLinkClass =
  'block px-3 py-2 rounded-md text-base font-medium hover:bg-brand-red';

const simpleNavItems = mainNav.filter(
  (item) => item.label !== 'Services' && item.label !== 'Service Areas',
);
---

    <header class="bg-brand-black text-white sticky top-0 z-50 shadow-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex-shrink-0 flex items-center">
                    <Logo />
                </div>
                
                <nav class="hidden md:flex space-x-6 items-center" aria-label="Primary">
                    {simpleNavItems.slice(0, 2).map((item) => (
                        <NavLink href={item.href} label={item.label} class={desktopLinkClass} />
                    ))}
                    <NavDropdown menu={navMenus.services} linkClass={desktopLinkClass} />
                    <NavDropdown menu={navMenus.serviceAreas} linkClass={desktopLinkClass} />
                    {simpleNavItems.slice(2).map((item) => (
                        <NavLink href={item.href} label={item.label} class={desktopLinkClass} />
                    ))}
                    <NavLink href="/pricing/" label="Pricing" class={desktopLinkClass} />
                    <NavLink href="/reviews/" label="Reviews" class={desktopLinkClass} />
                </nav>

                <div class="hidden md:flex items-center bg-brand-red/10 px-4 py-2 rounded-md border border-brand-red/20">
                    <div class="flex flex-col items-end">
                        <span class="text-xs text-brand-red font-bold uppercase tracking-wider">Need Help?</span>
                        <a href={`tel:${site.phoneTel}`} class="font-bold text-lg hover:text-brand-red transition-colors">{site.phone}</a>
                    </div>
                </div>

                <div class="flex items-center md:hidden">
                    <button
                      type="button"
                      id="mobile-menu-toggle"
                      class="text-gray-300 hover:text-white focus:outline-none p-2"
                      aria-label="Toggle menu"
                      aria-controls="mobile-menu"
                      aria-expanded="false"
                    >
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>

    </header>

    <!--
      The mobile menu + backdrop live OUTSIDE the sticky <header> on purpose.
      A position:fixed element nested inside a position:sticky ancestor can
      anchor to the header's stuck offset (browser quirk) instead of the
      viewport, which made the menu open at the top of the page when scrolled
      down. As siblings of the header they are reliably viewport-relative.
      Extra bottom padding on the nav clears the mobile sticky CTA.
    -->
    <div
      id="mobile-menu-backdrop"
      class="hidden md:hidden fixed left-0 right-0 top-20 bottom-0 z-40 bg-black/40"
      aria-hidden="true"
    ></div>
    <div
      id="mobile-menu"
      class="hidden md:hidden fixed left-0 right-0 top-20 z-40 bg-brand-charcoal text-white border-t border-gray-800 max-h-[calc(100dvh-5rem)] overflow-y-auto overscroll-contain [-webkit-overflow-scrolling:touch]"
    >
        <nav
          aria-label="Primary"
          class="px-2 pt-2 pb-[calc(5.5rem+env(safe-area-inset-bottom,0px))] space-y-1 sm:px-3"
        >
            {simpleNavItems.map((item) => (
                <NavLink href={item.href} label={item.label} class={mobileLinkClass} closeMobileMenu />
            ))}
            <NavMobileAccordion menu={navMenus.services} mobileLinkClass={mobileLinkClass} />
            <NavMobileAccordion menu={navMenus.serviceAreas} mobileLinkClass={mobileLinkClass} />
            <NavLink href="/pricing/" label="Pricing" class={mobileLinkClass} closeMobileMenu />
            <NavLink href="/reviews/" label="Reviews" class={mobileLinkClass} closeMobileMenu />
            <NavLink href="/blog/" label="Blog" class={mobileLinkClass} closeMobileMenu />
            <a href={`tel:${site.phoneTel}`} class="block px-3 py-3 mt-4 bg-brand-red text-white text-center rounded-md font-bold text-lg">Call: {site.phone}</a>
        </nav>
    </div>

    <script>
      function setMobileMenuOpen(open) {
        const menu = document.getElementById('mobile-menu');
        const backdrop = document.getElementById('mobile-menu-backdrop');
        const toggle = document.getElementById('mobile-menu-toggle');
        if (!menu || !toggle) return;
        menu.classList.toggle('hidden', !open);
        backdrop?.classList.toggle('hidden', !open);
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      }

      document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
        const menu = document.getElementById('mobile-menu');
        if (!menu) return;
        setMobileMenuOpen(menu.classList.contains('hidden'));
      });

      // Tapping the backdrop (anywhere outside the nav) closes the menu.
      document.getElementById('mobile-menu-backdrop')?.addEventListener('click', () => {
        setMobileMenuOpen(false);
      });

      document.getElementById('mobile-menu')?.addEventListener('click', (event) => {
        const target = event.target;
        if (target instanceof Element && target.closest('[data-close-mobile-menu]')) {
          setMobileMenuOpen(false);
        }
      });
    </script>
