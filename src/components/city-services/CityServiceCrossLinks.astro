---
interface CommunityLink {
  title: string;
  href: string;
}

interface Props {
  cityTitle: string;
  cityHref: string;
  serviceTitle: string;
  serviceHref: string;
  communities: CommunityLink[];
  embedded?: boolean;
}

const { cityTitle, cityHref, serviceTitle, serviceHref, communities, embedded = false } =
  Astro.props;
---

{
  embedded ? (
    <section aria-labelledby="city-service-links">
      <h2 id="city-service-links" class="text-2xl font-bold text-brand-black mb-6">
        Explore related pages
      </h2>
      <ul class="space-y-3 text-sm">
        <li>
          <a href={cityHref} class="font-medium text-brand-black hover:text-brand-red transition-colors">
            All services in {cityTitle} &rarr;
          </a>
        </li>
        <li>
          <a href={serviceHref} class="font-medium text-brand-black hover:text-brand-red transition-colors">
            {serviceTitle} across our full service area &rarr;
          </a>
        </li>
        <li>
          <a href="/service-areas/" class="font-medium text-brand-black hover:text-brand-red transition-colors">
            View all service areas &rarr;
          </a>
        </li>
      </ul>
      {
        communities.length > 0 && (
          <div class="mt-8">
            <h3 class="font-bold text-brand-black mb-3 text-sm uppercase tracking-wide">
              {cityTitle} communities we serve
            </h3>
            <ul class="flex flex-wrap gap-2">
              {communities.map((c) => (
                <li>
                  <a
                    href={c.href}
                    class="inline-block px-3 py-1.5 bg-white border border-gray-200 rounded-full text-sm font-medium text-brand-black hover:border-brand-red hover:text-brand-red transition-colors"
                  >
                    {c.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </section>
  ) : (
    <section class="py-12 bg-brand-lightbg border-t border-gray-200" aria-labelledby="city-service-links">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="city-service-links" class="text-2xl font-bold text-brand-black mb-6">
          Explore related pages
        </h2>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={cityHref} class="font-medium text-brand-black hover:text-brand-red transition-colors">
              All services in {cityTitle} &rarr;
            </a>
          </li>
          <li>
            <a href={serviceHref} class="font-medium text-brand-black hover:text-brand-red transition-colors">
              {serviceTitle} across our full service area &rarr;
            </a>
          </li>
          <li>
            <a href="/service-areas/" class="font-medium text-brand-black hover:text-brand-red transition-colors">
              View all service areas &rarr;
            </a>
          </li>
        </ul>
        {
          communities.length > 0 && (
            <div class="mt-8">
              <h3 class="font-bold text-brand-black mb-3 text-sm uppercase tracking-wide">
                {cityTitle} communities we serve
              </h3>
              <ul class="flex flex-wrap gap-2">
                {communities.map((c) => (
                  <li>
                    <a
                      href={c.href}
                      class="inline-block px-3 py-1.5 bg-white border border-gray-200 rounded-full text-sm font-medium text-brand-black hover:border-brand-red hover:text-brand-red transition-colors"
                    >
                      {c.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>
    </section>
  )
}
