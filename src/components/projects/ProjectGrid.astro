---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
  initialCount?: number;
}

const { projects, initialCount = 12 } = Astro.props;
---

<div data-project-grid>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" data-project-grid-inner>
    {
      projects.map((project, index) => (
        <ProjectCard project={project} hidden={index >= initialCount} />
      ))
    }
  </div>

  <div class="mt-10 text-center" data-show-more-wrap class:list={[projects.length <= initialCount && 'hidden']}>
    <button
      type="button"
      class="inline-flex items-center justify-center border-2 border-brand-black text-brand-black px-8 py-3.5 rounded-md font-bold hover:bg-brand-black hover:text-white transition-colors min-h-11"
      data-show-more
      data-page-size="9"
      data-initial={initialCount}
    >
      Show More Projects
    </button>
  </div>

  <div
    class="hidden mt-10 text-center rounded-xl border border-brand-line bg-brand-lightbg px-6 py-10"
    data-empty-state
    hidden
  >
    <p class="text-gray-700 mb-6 max-w-lg mx-auto">
      No projects are currently available in this category. Explore all projects or request an estimate for your own project.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <button
        type="button"
        class="gradient-btn text-white px-6 py-3 rounded-md font-bold min-h-11"
        data-filter-reset
      >
        View All Projects
      </button>
      <a
        href="/contact/"
        class="inline-flex items-center border-2 border-brand-black px-6 py-3 rounded-md font-bold min-h-11"
      >
        Request an Estimate
      </a>
    </div>
  </div>
</div>
