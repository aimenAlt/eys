---
import BalancedGrid from '../ui/BalancedGrid.astro';

interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
  type?: string;
  featured?: boolean;
}

interface Props {
  images?: GalleryImage[];
}

const { images } = Astro.props;

const galleryItems = (images ?? []).map((image) => ({
  src: image.src,
  alt: image.alt,
  caption: image.caption,
  type: image.type,
}));
---

{
  galleryItems.length > 0 && (
    <section aria-labelledby="project-gallery">
      <h2 id="project-gallery" class="sr-only">Project Gallery</h2>
      <BalancedGrid variant="gallery" items={galleryItems} cols={3} gapClass="gap-6" />
    </section>
  )
}
